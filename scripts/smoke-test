#!/usr/bin/env bash
set -euo pipefail

php craft plugin/list

php craft exec '
use Craft;
use lindemannrock\smartlinkmanager\SmartLinkManager;
use lindemannrock\smartlinkmanager\models\Settings;
use lindemannrock\logginglibrary\LoggingLibrary;

$plugins = Craft::$app->getPlugins();
$plugin = $plugins->getPlugin("smartlink-manager");

if (!$plugin instanceof SmartLinkManager) {
    throw new RuntimeException("SmartLink Manager plugin class was not loaded.");
}

foreach (["smartlink-manager", "logging-library"] as $handle) {
    if (!$plugins->isPluginInstalled($handle) || !$plugins->isPluginEnabled($handle)) {
        throw new RuntimeException("Required Craft plugin is not installed and enabled: {$handle}");
    }
}

if (!$plugins->getPlugin("logging-library") instanceof LoggingLibrary) {
    throw new RuntimeException("Logging Library dependency was not loaded.");
}

$baseModule = Craft::$app->getModule("lindemannrock-base");
if (!$baseModule instanceof \yii\base\Module) {
    throw new RuntimeException("Base module was not registered.");
}

$settings = $plugin->getSettings();
if (!$settings instanceof Settings) {
    throw new RuntimeException("SmartLink Manager settings model was not loaded.");
}

if ($settings->slugPrefix !== "go" || $settings->qrPrefix !== "go/qr" || $settings->defaultQrSize !== 256 || $settings->enableAnalytics !== true) {
    throw new RuntimeException("SmartLink Manager fresh-install settings defaults are not intact.");
}

foreach (["smartLinks", "analytics", "qrCode", "deviceDetection", "integration"] as $component) {
    if (!$plugin->has($component)) {
        throw new RuntimeException("Missing SmartLink Manager service component: {$component}");
    }
    $plugin->get($component);
}

echo "SmartLink Manager smoke test passed.\n";
'
