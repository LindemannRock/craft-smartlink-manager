{% extends "smartlink-manager/_layouts/cp" %}
{% set title = "Preview Import"|t('smartlink-manager') %}
{% set fullPageForm = false %}
{% set selectedSubnavItem = 'import-export' %}

{% set crumbs = [
    { label: smartlinkHelper.fullName|t('smartlink-manager'), url: url('smartlink-manager') },
    { label: 'Import/Export'|t('smartlink-manager'), url: url('smartlink-manager/import-export') },
    { label: 'Preview'|t('smartlink-manager') }
] %}

{% block content %}
    <h2 class="first">{{ "Import Preview"|t('smartlink-manager') }}</h2>

    <div class="lr-unified-cards cols-4 lr-mt-30 lr-mb-30">
        {% include 'lindemannrock-base/_components/unified-card' with { value: summary.totalRows, description: 'Total Rows'|t('smartlink-manager'), align: 'center' } only %}
        {% include 'lindemannrock-base/_components/unified-card' with { value: summary.validRows, description: 'Valid'|t('smartlink-manager'), palette: 'green', align: 'center' } only %}
        {% include 'lindemannrock-base/_components/unified-card' with { value: summary.duplicates, description: 'Duplicates'|t('smartlink-manager'), palette: 'amber', align: 'center' } only %}
        {% include 'lindemannrock-base/_components/unified-card' with { value: summary.errors, description: 'Errors'|t('smartlink-manager'), palette: 'red', align: 'center' } only %}
    </div>

    {% if validRows|length %}
        <hr>
        <h3>{{ "Valid Smart Links to Import"|t('smartlink-manager') }} ({{ validRows|length }})</h3>
        <div class="lr-preview-table lr-preview-table--tall">
            <table class="data fullwidth">
                <thead>
                    <tr>
                        <th>{{ 'Slug'|t('smartlink-manager') }}</th>
                        <th>{{ 'Title'|t('smartlink-manager') }}</th>
                        <th>{{ 'Fallback URL'|t('smartlink-manager') }}</th>
                        <th>{{ 'Image ID'|t('smartlink-manager') }}</th>
                        <th>{{ 'Enabled'|t('smartlink-manager') }}</th>
                        <th>{{ 'Site'|t('smartlink-manager') }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for row in validRows %}
                        <tr>
                            <td><code class="lr-cell-clip" title="{{ row.slug }}">{{ row.slug }}</code></td>
                            <td>{{ row.title }}</td>
                            <td><code class="lr-cell-clip" title="{{ row.fallbackUrl }}">{{ row.fallbackUrl }}</code></td>
                            <td>{% if row.imageId %}{{ row.imageId }}{% else %}-{% endif %}</td>
                            <td>{{ row.enabled ? 'Yes'|t('smartlink-manager') : 'No'|t('smartlink-manager') }}</td>
                            <td>
                                {% if row.siteId %}
                                    {% set importSite = craft.app.sites.getSiteById(row.siteId) %}
                                    {{ importSite ? importSite.name : row.siteId }}
                                {% else %}
                                    {{ craft.app.sites.currentSite.name }}
                                {% endif %}
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}

    {% if duplicateRows|length %}
        <hr>
        <h3>{{ 'Duplicates (will be skipped)'|t('smartlink-manager') }} ({{ duplicateRows|length }})</h3>
        <div class="lr-preview-table">
            <table class="data fullwidth">
                <thead class="is-warning">
                    <tr>
                        <th>{{ 'Slug'|t('smartlink-manager') }}</th>
                        <th>{{ 'Fallback URL'|t('smartlink-manager') }}</th>
                        <th>{{ 'Reason'|t('smartlink-manager') }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for row in duplicateRows %}
                        <tr>
                            <td><code class="lr-cell-clip" title="{{ row.slug }}">{{ row.slug }}</code></td>
                            <td><code class="lr-cell-clip" title="{{ row.fallbackUrl }}">{{ row.fallbackUrl }}</code></td>
                            <td>{{ row.reason }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}

    {% if errorRows|length %}
        <hr>
        <h3>{{ 'Invalid Rows (will be skipped)'|t('smartlink-manager') }} ({{ errorRows|length }})</h3>
        <div class="lr-preview-table">
            <table class="data fullwidth">
                <thead class="is-error">
                    <tr>
                        <th>{{ 'Row'|t('smartlink-manager') }}</th>
                        <th>{{ 'Slug'|t('smartlink-manager') }}</th>
                        <th>{{ 'Fallback URL'|t('smartlink-manager') }}</th>
                        <th>{{ 'Error'|t('smartlink-manager') }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for row in errorRows %}
                        <tr>
                            <td>{{ row.rowNumber }}</td>
                            <td><code class="lr-cell-clip" title="{{ row.slug }}">{{ row.slug }}</code></td>
                            <td><code class="lr-cell-clip" title="{{ row.fallbackUrl }}">{{ row.fallbackUrl }}</code></td>
                            <td>{{ row.error }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}

    <hr>

    <form method="post" action="{{ actionUrl('smartlink-manager/import-export/import') }}" id="importForm">
        {{ csrfInput() }}
        <div class="lr-import-summary">
            <h3 class="first">{{ "Ready to Import"|t('smartlink-manager') }}</h3>
            <p>
                {% if summary.validRows > 0 %}
                    {{ "Click the button below to import {count} valid smart link(s)."|t('smartlink-manager', {count: summary.validRows}) }}
                    {% if summary.duplicates > 0 %}
                        {{ "{duplicates} duplicate(s) will be skipped."|t('smartlink-manager', {duplicates: summary.duplicates}) }}
                    {% endif %}
                    {% if summary.errors > 0 %}
                        {{ "{errors} invalid row(s) will be skipped."|t('smartlink-manager', {errors: summary.errors}) }}
                    {% endif %}
                {% else %}
                    {{ "No valid smart links found to import."|t('smartlink-manager') }}
                {% endif %}
            </p>
            <div class="buttons">
                <a href="{{ url('smartlink-manager/import-export') }}" class="btn secondary">{{ 'Cancel'|t('smartlink-manager') }}</a>
                {% if summary.validRows > 0 %}
                    <button type="submit" class="btn submit">{{ 'Import {count} Smart Links'|t('smartlink-manager', {count: summary.validRows}) }}</button>
                {% else %}
                    <button type="button" class="btn disabled" disabled>{{ 'No Valid Smart Links to Import'|t('smartlink-manager') }}</button>
                {% endif %}
            </div>
        </div>
    </form>

    {% include 'lindemannrock-base/_components/plugin-credit' %}
{% endblock %}

{% js %}
const importForm = document.getElementById('importForm');
if (importForm) {
    importForm.addEventListener('submit', function(e) {
        const confirmMessage = {{ 'Import {count} smart link(s)?'|t('smartlink-manager', {count: summary.validRows})|json_encode|raw }};
        if (!confirm(confirmMessage)) {
            e.preventDefault();
        }
    });
}
{% endjs %}
