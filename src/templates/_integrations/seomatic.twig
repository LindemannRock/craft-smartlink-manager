{#
  SEOmatic integration tracking template
  Pushes smart link events to Google Tag Manager dataLayer
#}
{% set smartlinkPlugin = craft.app.plugins.getPlugin('smartlink-manager') %}
{% set settings = smartlinkPlugin ? smartlinkPlugin.settings : null %}
{% set enabledIntegrations = settings.enabledIntegrations ?? [] %}
{% set trackingEvents = settings.seomaticTrackingEvents ?? ['redirect', 'button_click', 'qr_scan'] %}
{% set seomaticEnabled = settings
    and craft.app.plugins.isPluginEnabled('seomatic')
    and 'seomatic' in enabledIntegrations
    and eventType in trackingEvents
%}

{% if seomaticEnabled %}
    {% set eventPrefix = settings.seomaticEventPrefix ?? 'smart_links' %}
    <script>
        window.dataLayer = window.dataLayer || [];

        {% if eventType == 'qr_scan' %}
        (function() {
            var eventData = {
                event: '{{ eventPrefix|e('js') }}_qr_scan',
                smart_link: {
                    slug: '{{ smartLink.slug|e('js') }}',
                    title: '{{ smartLink.title|e('js') }}',
                    source: 'qr',
                    click_type: 'qr_scan'
                }
            };
            window.dataLayer.push(eventData);
            {% if craft.app.config.general.devMode %}
            console.log('SmartLink Manager QR scan event pushed:', eventData);
            {% endif %}
        })();
        {% else %}
        function pushSmartLinkEvent(eventType, platform, source) {
            var eventData = {
                event: '{{ eventPrefix|e('js') }}_' + eventType,
                smart_link: {
                    slug: '{{ smartLink.slug|e('js') }}',
                    title: '{{ smartLink.title|e('js') }}',
                    platform: platform,
                    source: source || 'direct',
                    click_type: eventType
                }
            };
            window.dataLayer.push(eventData);
            {% if craft.app.config.general.devMode %}
            console.log('SmartLink Manager event pushed to dataLayer:', eventData);
            console.log('Current dataLayer length:', window.dataLayer.length);
            console.log('Last 3 dataLayer events:', window.dataLayer.slice(-3));
            {% endif %}
        }

        function platformFromTrackedUrl(url) {
            var queryPlatform = url.searchParams.get('platform');
            if (queryPlatform) {
                return queryPlatform;
            }

            var pathParts = url.pathname.split('/').filter(Boolean);
            var goIndex = pathParts.indexOf('go');
            if (
                goIndex !== -1 &&
                pathParts[goIndex - 1] === 'redirect' &&
                pathParts[goIndex - 2] === 'smartlink-manager' &&
                pathParts[goIndex + 2]
            ) {
                return pathParts[goIndex + 2];
            }

            return 'unknown';
        }

        (function() {
            var urlParams = new URLSearchParams(window.location.search);
            var source = urlParams.get('src') || 'direct';
            pushSmartLinkEvent('redirect', 'auto', source);
        })();

        document.addEventListener('DOMContentLoaded', function() {
            var appLinks = document.querySelectorAll('a[href*="smartlink-manager/redirect/go"]');

            appLinks.forEach(function(link) {
                link.addEventListener('click', function(e) {
                    e.preventDefault();
                    var url = new URL(link.href);
                    var platform = platformFromTrackedUrl(url);
                    var urlParams = new URLSearchParams(window.location.search);
                    var source = urlParams.get('src') || 'direct';
                    pushSmartLinkEvent('button_click', platform, source);

                    setTimeout(function() {
                        window.location.href = link.href;
                    }, 300);
                });
            });
        });
        {% endif %}
    </script>
{% endif %}
