{# Traffic & Devices Tab - Device Types, Device Brands, Browsers, OS, Peak Hours #}

<h2 class="lr-section-heading">{{ "Device Analytics"|t('smartlink-manager') }}</h2>

<div class="lr-analytics-charts two-columns">
    <div class="lr-chart-container">
        <h3>{{ "Device Types"|t('smartlink-manager') }}</h3>
        <canvas id="device-chart"></canvas>
    </div>

    <div class="lr-chart-container">
        <h3>{{ "Traffic Type"|t('smartlink-manager') }}</h3>
        <canvas id="traffic-type-chart"></canvas>
    </div>
</div>

<div class="lr-analytics-charts lr-mt-30">
    <div class="lr-chart-container full-width">
        <h3>{{ "Top Agents"|t('smartlink-manager') }}</h3>
        <div class="lr-table-scroll">
            <table class="data fullwidth">
                <thead>
                    <tr>
                        <th>{{ "Agent"|t('smartlink-manager') }}</th>
                        <th>{{ "Traffic Type"|t('smartlink-manager') }}</th>
                        <th>{{ "Category"|t('smartlink-manager') }}</th>
                        <th>{{ "Producer"|t('smartlink-manager') }}</th>
                        <th>{{ "Interactions"|t('smartlink-manager') }}</th>
                    </tr>
                </thead>
                <tbody id="top-agents-body">
                    <tr>
                        <td colspan="5" class="thin light lr-text-center">{{ "No agent data available"|t('smartlink-manager') }}</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="lr-analytics-charts two-columns lr-mt-30">
    <div class="lr-chart-container">
        <h3>{{ "Device Brands"|t('smartlink-manager') }}</h3>
        <canvas id="brand-chart"></canvas>
    </div>
    <div class="lr-chart-container">
        <h3>{{ "Operating Systems"|t('smartlink-manager') }}</h3>
        <canvas id="os-chart"></canvas>
    </div>

    <div class="lr-chart-container">
        <h3>{{ "Browser Usage"|t('smartlink-manager') }}</h3>
        <canvas id="browser-chart"></canvas>
    </div>
</div>

<h2 class="lr-section-heading">{{ "Usage Patterns"|t('smartlink-manager') }}</h2>

<div class="lr-analytics-charts">
    <div class="lr-chart-container full-width">
        <h3>{{ "Peak Usage Hours"|t('smartlink-manager') }}</h3>
        <canvas id="hourly-chart"></canvas>
        <div id="peak-hour-info" class="lr-peak-label"></div>
    </div>
</div>
