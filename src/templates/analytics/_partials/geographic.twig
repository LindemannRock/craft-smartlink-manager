{# Geographic Tab - Countries and Cities (loaded via AJAX) #}

{% set settings = craft.app.plugins.getPlugin('smartlink-manager').settings %}

{% if settings.enableGeoDetection %}
    <h2 class="lr-section-heading">{{ "Geographic Distribution"|t('smartlink-manager') }}</h2>

    <div class="lr-analytics-charts two-columns">
        <div class="lr-chart-container">
            <h3>{{ "Top Countries"|t('smartlink-manager') }}</h3>
            <div class="lr-table-scroll">
                <table class="data fullwidth">
                    <thead>
                        <tr>
                            <th>{{ "Country"|t('smartlink-manager') }}</th>
                            <th>{{ "Interactions"|t('smartlink-manager') }}</th>
                            <th>{{ "Percentage"|t('smartlink-manager') }}</th>
                        </tr>
                    </thead>
                    <tbody id="geo-countries-body">
                        <tr>
                            <td colspan="3" class="light lr-text-center">
                                <div class="spinner"></div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="lr-chart-container">
            <h3>{{ "Top Cities"|t('smartlink-manager') }}</h3>
            <div class="lr-table-scroll">
                <table class="data fullwidth">
                    <thead>
                        <tr>
                            <th>{{ "City"|t('smartlink-manager') }}</th>
                            <th>{{ "Country"|t('smartlink-manager') }}</th>
                            <th>{{ "Interactions"|t('smartlink-manager') }}</th>
                            <th>{{ "Percentage"|t('smartlink-manager') }}</th>
                        </tr>
                    </thead>
                    <tbody id="geo-cities-body">
                        <tr>
                            <td colspan="4" class="light lr-text-center">
                                <div class="spinner"></div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% else %}
    <div class="pane lr-analytics-empty">
        <p>{{ "Geographic detection is disabled."|t('smartlink-manager') }}</p>
        <p><a href="{{ url('smartlink-manager/settings/analytics') }}" class="btn">{{ "Enable in Settings"|t('smartlink-manager') }}</a></p>
    </div>
{% endif %}
