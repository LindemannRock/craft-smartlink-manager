{% extends "smartlink-manager/_layouts/cp" %}
{% import "_includes/forms" as forms %}
{% do view.registerAssetBundle('lindemannrock\\base\\web\\assets\\components\\ComponentsAsset') %}
{% do view.registerAssetBundle('lindemannrock\\smartlinkmanager\\web\\assets\\edit\\EditAsset') %}
{% set plugin = craft.app.plugins.getPlugin('smartlink-manager') %}

{% set title = smartLink.id ? smartLink.title : "New {singularName}"|t('smartlink-manager', {singularName: smartlinkHelper.displayName}) %}
{% set fullPageForm = true %}
{% set selectedSubnavItem = 'links' %}
{% set saveShortcutRedirect = 'smartlink-manager/smartlinks/{id}' %}
{% set retainScrollOnSaveShortcut = true %}
{% set canViewAnalytics = currentUser.can('smartLinkManager:viewAnalytics') %}

{% set tabs = {
    fields: {
        label: 'Details'|t('smartlink-manager'),
        url: '#fields',
    },
} %}
{% set smartLinkSite = craft.app.sites.getSiteById(smartLink.siteId) %}
{% set smartLinkSiteHandle = smartLinkSite ? smartLinkSite.handle : null %}

{% set editConfig = {
    generateSlug: not smartLink.id,
    confirmAnalyticsDisable: canViewAnalytics and craft.smartLinks.settings.enableAnalytics,
    defaults: {
        qrSize: craft.smartLinks.settings.defaultQrSize,
        qrColor: craft.smartLinks.settings.defaultQrColor,
        qrBgColor: craft.smartLinks.settings.defaultQrBgColor,
        qrEyeColor: craft.smartLinks.settings.qrEyeColor ?? '',
        qrFormat: craft.smartLinks.settings.defaultQrFormat ?? 'png',
    },
    urls: {
        qrPublicBaseUrl: smartLink.id ? craft.smartLinks.settings.buildPublicUrl((craft.smartLinks.settings.qrPrefix ?: 'qr') ~ '/' ~ smartLink.slug, smartLink.siteId) : null,
    },
    messages: {
        enterCustomSize: 'Enter custom size (100-4096 pixels):'|t('smartlink-manager'),
        invalidCustomSize: 'Please enter a valid size between 100 and 4096 pixels'|t('smartlink-manager'),
        resetQrDefaultsConfirm: 'Reset QR code settings to plugin defaults?'|t('smartlink-manager'),
        qrDefaultsReset: 'QR code settings reset to defaults'|t('smartlink-manager'),
        disableAnalyticsConfirm: 'Are you sure you want to disable analytics tracking for this {singularName}? This {singularName} will no longer collect visitor data and interactions.'|t('smartlink-manager', {singularName: smartlinkHelper.lowerDisplayName}),
    },
} %}

{% if smartLink.id %}
    {% do view.registerAssetBundle('lindemannrock\\smartlinkmanager\\web\\assets\\qrpreview\\QrPreviewAsset') %}
    {% set qrPreviewConfig = {
        generateUrl: actionUrl('smartlink-manager/qr-code/generate', { slug: smartLink.slug, siteHandle: smartLinkSiteHandle }),
        fields: {
            size: 'qrCodeSize',
            format: 'qrCodeFormat',
            color: 'qrCodeColor',
            bg: 'qrCodeBgColor',
            eyeColor: 'qrCodeEyeColor',
        },
        defaults: {
            size: smartLink.qrCodeSize ?? craft.smartLinks.settings.defaultQrSize,
            format: smartLink.qrCodeFormat ?: (craft.smartLinks.settings.defaultQrFormat ?? 'png'),
            color: smartLink.qrCodeColor ?: craft.smartLinks.settings.defaultQrColor,
            bg: smartLink.qrCodeBgColor ?: craft.smartLinks.settings.defaultQrBgColor,
            margin: craft.smartLinks.settings.defaultQrMargin,
            errorCorrection: craft.smartLinks.settings.defaultQrErrorCorrection ?? 'M',
            moduleStyle: craft.smartLinks.settings.qrModuleStyle ?? 'square',
            eyeStyle: craft.smartLinks.settings.qrEyeStyle ?? 'square',
            logoSize: craft.smartLinks.settings.qrLogoSize ?? 20,
        },
        logo: {
            enabled: craft.smartLinks.settings.enableQrLogo,
            defaultLogoId: craft.smartLinks.settings.defaultQrLogoId ?? null,
            fieldId: 'qrLogoId-field',
            fieldSelector: '#qrLogoId-field .elements .element',
        },
        preview: {
            size: 150,
            imageSelector: '#qr-preview',
        },
        link: {
            selector: '#qr-preview-link',
            baseUrl: craft.smartLinks.settings.buildPublicUrl((craft.smartLinks.settings.qrPrefix ?: 'qr') ~ '/' ~ smartLink.slug, smartLink.siteId),
        },
        messages: {
            failed: 'Failed to generate preview'|t('smartlink-manager'),
        },
    } %}
{% endif %}

{# Add tabs from field layout #}
{% set fieldLayoutTabs = [] %}
{% set fieldLayout = smartLink.getFieldLayout() %}
{% if fieldLayout %}
    {% for tab in fieldLayout.getTabs() %}
        {% if tab.getElements() %}
            {% set fieldLayoutTabs = fieldLayoutTabs|merge([tab]) %}
            {% set tabId = 'tab-' ~ tab.id %}
            {% set tabs = tabs|merge({
                (tabId): {
                    label: tab.name,
                    url: '#' ~ tabId,
                }
            }) %}
        {% endif %}
    {% endfor %}
{% endif %}

{# Only show analytics tab if globally enabled, permitted, smart link exists, AND tracking is enabled for this smart link #}
{% if canViewAnalytics and craft.smartLinks.settings.enableAnalytics and smartLink.id and (smartLink.trackAnalytics ?? true) %}
    {% set tabs = tabs|merge({
        analytics: {
            label: 'Analytics'|t('smartlink-manager'),
            url: '#analytics',
        },
    }) %}
{% endif %}

{# Set up breadcrumbs #}
{% set crumbs = [] %}

{# Site switcher (first item) #}
{% if craft.app.getIsMultiSite() %}
    {% set currentSite = craft.app.sites.getSiteById(smartLink.siteId) %}

    {# Get site menu items #}
    {% set siteMenuItems = [] %}
    {% for site in enabledSites %}
        {% set siteMenuItems = siteMenuItems|merge([{
            label: site.name,
            url: smartLink.id ? url('smartlink-manager/smartlinks/' ~ smartLink.id, {site: site.handle}) : url('smartlink-manager/new', {site: site.handle}),
            selected: site.id == smartLink.siteId
        }]) %}
    {% endfor %}

    {% set crumbs = [{
        id: 'site-crumb',
        icon: 'world',
        label: currentSite.name|t('site'),
        menu: {
            items: siteMenuItems,
            label: 'Select site'|t('smartlink-manager')
        }
    }] %}
{% endif %}

{# Main navigation #}
{% set crumbs = crumbs|merge([
    {
        label: smartlinkHelper.fullName|t('smartlink-manager'),
        url: url('smartlink-manager')
    }
]) %}

{% if smartLink.id %}
    {% set crumbs = crumbs|merge([{
        label: smartLink.title,
        url: url('smartlink-manager/smartlinks/' ~ smartLink.id)
    }]) %}

{% endif %}

{% block contextMenu %}
    {# No revisions support for now #}
{% endblock %}


{% block actionButton %}
    {% if smartLink.id %}
        <div class="preview-btn-container btngroup">
            {% set viewLabel = smartlinkHelper.displayName %}
            <a href="{{ smartLink.getRedirectUrl() }}" target="_blank" class="btn">{{ 'View'|t('smartlink-manager') }}</a>
            <button type="button" class="btn menubtn"></button>
            <div class="menu">
                <ul role="listbox">
                    <li>
                        <a role="option" tabindex="0" href="{{ smartLink.getRedirectUrl() }}" target="_blank">
                            {{ viewLabel }}
                        </a>
                    </li>
                    {% if smartLink.qrCodeEnabled %}
                        <li>
                            <a role="option" tabindex="0" href="{{ smartLink.getQrCodeUrl() }}" target="_blank">
                                {{ "QR Code Image"|t('smartlink-manager') }}
                            </a>
                        </li>
                        <li>
                            <a role="option" tabindex="0" href="{{ smartLink.getQrCodeDisplayUrl() }}" target="_blank">
                                {{ "QR Code Page"|t('smartlink-manager') }}
                            </a>
                        </li>
                    {% endif %}
                </ul>
            </div>
        </div>
    {% endif %}
    <div class="btngroup submit">
        <button type="submit" class="btn submit">{{ "Save"|t('smartlink-manager') }}</button>
        <button type="button" class="btn submit menubtn"></button>
        <div class="menu">
            <ul role="listbox">
                <li>
                    <a class="formsubmit" role="option" tabindex="0" data-redirect="{{ url('smartlink-manager/{id}', {site: currentSite.handle})|hash }}">
                        <span class="label">{{ 'Save and continue editing'|t('smartlink-manager') }}</span>
                        <span class="shortcut" id="save-shortcut"></span>
                    </a>
                </li>
            </ul>
        </div>
    </div>
    {% if smartLink.id and currentUser.can('smartLinkManager:deleteLinks') %}
        <button type="button" id="action-btn" class="btn menubtn action-btn hairline-dark m" title="{{ 'Actions'|t('smartlink-manager') }}" aria-controls="action-menu" aria-label="{{ 'Actions'|t('smartlink-manager') }}" data-disclosure-trigger="true" aria-expanded="false"></button>
        <div id="action-menu" class="menu menu--disclosure">
            <ul>
                <li>
                    <button class="menu-item error formsubmit" data-destructive data-action="smartlink-manager/smartlinks/delete" data-params='{"id":{{ smartLink.id }}}' data-confirm="{{ 'Are you sure you want to delete this entry?'|t('smartlink-manager') }}" data-redirect="{{ 'smartlink-manager'|hash }}" data-headers='{"Accept":"application/json"}'>
                        <span class="icon">{{ svg('@app/icons/trash.svg') }}</span>
                        <span class="menu-item-label">{{ "Delete"|t('smartlink-manager') }}</span>
                    </button>
                </li>
            </ul>
        </div>
    {% endif %}
{% endblock %}


{# Display validation errors summary before content #}
{% if smartLink is defined and smartLink.hasErrors() %}
    {% set errorSummary %}
        {% include 'lindemannrock-base/_partials/error-summary' with {
            errors: smartLink.getErrors(),
            linkMode: 'data-key',
            translationCategory: 'smartlink-manager'
        } %}
    {% endset %}
{% endif %}

{% block content %}
    <script type="application/json" data-smartlink-edit-config>{{ editConfig|json_encode|raw }}</script>

    <input type="hidden" name="action" value="smartlink-manager/smartlinks/save">
    {{ redirectInput('smartlink-manager') }}
    {% if smartLink.id %}
        <input type="hidden" name="smartLinkId" value="{{ smartLink.id }}">
        <input type="hidden" name="id" value="{{ smartLink.id }}">
    {% endif %}
    {% if craft.app.sites.getTotalEditableSites() > 1 %}
        <input type="hidden" name="siteId" value="{{ smartLink.siteId }}">
    {% endif %}

    <div id="fields">
        {% include "smartlink-manager/smartlinks/_partials/fields" %}

        {% include 'lindemannrock-base/_components/plugin-credit' %}
    </div>

    {# Render field layout tabs #}
    {% for tab in fieldLayoutTabs %}
        {% set tabId = 'tab-' ~ tab.id %}
        <div id="{{ tabId }}" class="hidden">
            {% for element in tab.getElements() %}
                {{ element.formHtml(smartLink, smartLink.getIsRevision())|raw }}
            {% endfor %}

            {% include 'lindemannrock-base/_components/plugin-credit' %}
        </div>
    {% endfor %}

    {% if canViewAnalytics and craft.smartLinks.settings.enableAnalytics and smartLink.id and (smartLink.trackAnalytics ?? true) %}
        <div id="analytics" class="hidden">
            {% include "smartlink-manager/smartlinks/_partials/analytics" with {
                smartLink: smartLink,
                analyticsService: analyticsService ?? null,
                settings: craft.smartLinks.settings
            } %}

            {% include 'lindemannrock-base/_components/plugin-credit' %}
        </div>
    {% endif %}
{% endblock %}

{% block details %}
    <div class="meta">
        <div id="slug-field" class="field" data-attribute="slug">
            <div class="heading">
                <label id="slug-label" for="slug">{{ "Slug"|t('smartlink-manager') }}
                    {% if craft.app.getIsMultiSite() %}
                        <craft-tooltip placement="bottom" max-width="200px" text="{{ 'This field is translated for each site.'|t('smartlink-manager') }}" delay="1000">
                            <button type="button" class="t9n-indicator prevent-autofocus" data-icon="language" aria-label="{{ 'This field is translated for each site.'|t('smartlink-manager') }}" style="pointer-events: auto;"></button>
                        </craft-tooltip>
                    {% endif %}
                </label>
            </div>
            <div class="input ltr">
                <input type="text" id="slug" class="text fullwidth" name="slug" value="{{ smartLink.slug }}" autocomplete="off" autocorrect="off" autocapitalize="none" dir="ltr" aria-labelledby="slug-label" {% if smartLink.getErrors('slug') %}aria-describedby="slug-errors" aria-invalid="true"{% endif %}>
            </div>
            {% if smartLink.getErrors('slug') %}
                <ul class="errors" id="slug-errors">
                    {% for error in smartLink.getErrors('slug') %}
                        <li>{{ error }}</li>
                    {% endfor %}
                </ul>
            {% endif %}
        </div>

        {# Author field #}
        {{ forms.elementSelectField({
            label: "Author"|t('smartlink-manager'),
            id: 'authorId',
            name: 'authorId',
            elementType: 'craft\\elements\\User',
            elements: smartLink.id and smartLink.getAuthor() ? [smartLink.getAuthor()] : [currentUser],
            sources: '*',
            criteria: {
                status: null
            },
            limit: 1,
            viewMode: 'small'
        }) }}

        {{ forms.dateTimeField({
            label: "Post Date"|t('smartlink-manager'),
            id: 'postDate',
            name: 'postDate',
            value: smartLink.postDate ?? smartLink.dateCreated ?? now,
            showTimeZone: false
        }) }}

        {{ forms.dateTimeField({
            label: "Expiry Date"|t('smartlink-manager'),
            id: 'expiryDate',
            name: 'expiryDate',
            value: smartLink.dateExpired,
            showTimeZone: false
        }) }}
    </div>

    {% if smartLink.id %}
        {% include 'lindemannrock-base/_components/copy-input' with {
            legend: "{pluginName} URL"|t('smartlink-manager', {pluginName: smartlinkHelper.displayName}),
            value: smartLink.getRedirectUrl(),
            id: 'smartlink-url',
            copyLabel: 'Copy'|t('smartlink-manager'),
            copiedMessage: 'URL copied to clipboard'|t('smartlink-manager'),
        } only %}
    {% endif %}

    <div class="meta">
        {{ forms.lightswitchField({
            label: "Enabled"|t('smartlink-manager'),
            id: 'enabled',
            name: 'enabled',
            on: smartLink.enabled
        }) }}

        {% if canViewAnalytics and craft.smartLinks.settings.enableAnalytics %}
            {{ forms.lightswitchField({
                label: "Track Analytics"|t('smartlink-manager'),
                id: 'trackAnalytics',
                name: 'trackAnalytics',
                on: smartLink.trackAnalytics ?? true
            }) }}
        {% elseif not craft.smartLinks.settings.enableAnalytics %}
            {# Hidden field to ensure trackAnalytics is set to false when analytics are disabled #}
            <input type="hidden" name="trackAnalytics" value="0">
        {% endif %}

        {{ forms.lightswitchField({
            label: "Enable QR Code"|t('smartlink-manager'),
            id: 'qrCodeEnabled',
            name: 'qrCodeEnabled',
            on: smartLink.qrCodeEnabled ?? true,
            toggle: 'qr-settings'
        }) }}
    </div>

    {% set hasQrFieldErrors = smartLink.getErrors('qrCodeSize')
        or smartLink.getErrors('qrCodeColor')
        or smartLink.getErrors('qrCodeBgColor')
        or smartLink.getErrors('qrCodeEyeColor') %}
    <fieldset id="qr-settings" class="{{ (not (smartLink.qrCodeEnabled ?? true) and not hasQrFieldErrors) ? 'hidden' }}">
        <legend class="h6">{{ "QR Code"|t('smartlink-manager') }}</legend>

        <div class="meta">
            {% if smartLink.id %}
                <script type="application/json" data-smartlink-qr-preview-config>{{ qrPreviewConfig|json_encode|raw }}</script>

                <div class="field">
                    <div class="heading">
                        <label>{{ "Preview"|t('smartlink-manager') }}</label>
                    </div>
                    <div class="input lr-text-center">
                        <a id="qr-preview-link" href="{{ smartLink.getQrCodeUrl() }}" target="_blank" title="{{ 'Click to view QR code image'|t('smartlink-manager') }}">
                            <img id="qr-preview"
                                 src="{{ actionUrl('smartlink-manager/qr-code/generate', { slug: smartLink.slug, siteHandle: smartLinkSiteHandle, size: 150 }) }}"
                                 alt="QR Code Preview"
                                 style="max-width: 150px; height: auto; border: 1px solid #e3e5e8; background: {{ smartLink.qrCodeBgColor ?? '#FFFFFF' }}; cursor: pointer;">
                        </a>
                    </div>
                </div>
            {% endif %}

            {{ forms.textField({
                label: "Size"|t('smartlink-manager'),
                id: 'qrCodeSize',
                name: 'qrCodeSize',
                value: smartLink.qrCodeSize ?? 256,
                type: 'number',
                min: 100,
                max: 1000,
                errors: smartLink.getErrors('qrCodeSize'),
                size: 5,
                fieldClass: ''
            }) }}

            {{ forms.colorField({
                label: "Color"|t('smartlink-manager'),
                id: 'qrCodeColor',
                name: 'qrCodeColor',
                value: smartLink.qrCodeColor ?: craft.smartLinks.settings.defaultQrColor,
                errors: smartLink.getErrors('qrCodeColor'),
                fieldClass: ''
            }) }}

            {{ forms.colorField({
                label: "Background"|t('smartlink-manager'),
                id: 'qrCodeBgColor',
                name: 'qrCodeBgColor',
                value: smartLink.qrCodeBgColor ?: craft.smartLinks.settings.defaultQrBgColor,
                errors: smartLink.getErrors('qrCodeBgColor'),
                fieldClass: ''
            }) }}

            {{ forms.colorField({
                label: "Eye Color"|t('smartlink-manager'),
                instructions: "Color for position markers (leave empty to use main color)"|t('smartlink-manager'),
                id: 'qrCodeEyeColor',
                name: 'qrCodeEyeColor',
                value: smartLink.qrCodeEyeColor ?: (craft.smartLinks.settings.qrEyeColor ?? ''),
                errors: smartLink.getErrors('qrCodeEyeColor'),
                fieldClass: ''
            }) }}

            {% set defaultFormat = craft.smartLinks.settings.defaultQrFormat ?? 'png' %}
            {{ forms.selectField({
                label: "Format"|t('smartlink-manager'),
                instructions: "Override the default QR code format"|t('smartlink-manager'),
                id: 'qrCodeFormat',
                name: 'qrCodeFormat',
                value: smartLink.qrCodeFormat ?? '',
                options: [
                    {label: 'Use Default ({format|upper})'|t('smartlink-manager', {'format|upper': defaultFormat|upper}), value: ''},
                    {label: 'PNG', value: 'png'},
                    {label: 'SVG', value: 'svg'},
                ],
                fieldClass: ''
            }) }}

            {# QR Logo field (only show if logos are enabled in settings) #}
            {% if craft.smartLinks.settings.enableQrLogo %}
                {% set logoSources = craft.smartLinks.settings.qrLogoVolumeUid ? ['volume:' ~ craft.smartLinks.settings.qrLogoVolumeUid] : '*' %}
                {% set selectedLogo = null %}
                {% if smartLink.qrLogoId %}
                    {% set selectedLogo = craft.assets.id(smartLink.qrLogoId).one() %}
                {% elseif craft.smartLinks.settings.defaultQrLogoId %}
                    {% set selectedLogo = craft.assets.id(craft.smartLinks.settings.defaultQrLogoId).one() %}
                {% endif %}

                {{ forms.elementSelectField({
                    label: "Logo"|t('smartlink-manager'),
                    instructions: smartLink.qrLogoId ? "Override the default QR code logo"|t('smartlink-manager') : "Using default logo from settings (click to override)"|t('smartlink-manager'),
                    id: 'qrLogoId',
                    name: 'qrLogoId',
                    elementType: 'craft\\elements\\Asset',
                    sources: logoSources,
                    criteria: {
                        kind: ['image']
                    },
                    limit: 1,
                    elements: selectedLogo ? [selectedLogo] : [],
                    fieldClass: ''
                }) }}
            {% endif %}

            <div class="field" style="margin-top: 15px;">
                <div class="heading">
                    <label>{{ "Actions"|t('smartlink-manager') }}</label>
                </div>
                <div class="input">
                    <div class="btngroup">
                        <button type="button" class="btn menubtn" data-icon="settings">{{ "QR Code Actions"|t('smartlink-manager') }}</button>
                        <div class="menu">
                            <ul>
                                {% if craft.smartLinks.settings.enableQrDownload and smartLink.id %}
                                    <li>
                                        <h6>{{ "Download QR Code"|t('smartlink-manager') }}</h6>
                                        <ul>
                                            <li><a class="download-qr" data-size="256" href="#">{{ "Small (256px)"|t('smartlink-manager') }}</a></li>
                                            <li><a class="download-qr" data-size="512" href="#">{{ "Medium (512px)"|t('smartlink-manager') }}</a></li>
                                            <li><a class="download-qr" data-size="1024" href="#">{{ "Large (1024px)"|t('smartlink-manager') }}</a></li>
                                            <li><a class="download-qr" data-size="2048" href="#">{{ "Extra Large (2048px)"|t('smartlink-manager') }}</a></li>
                                            <li><a class="download-qr" data-size="custom" href="#">{{ "Custom Size..."|t('smartlink-manager') }}</a></li>
                                        </ul>
                                    </li>
                                    <hr>
                                {% endif %}
                                <li>
                                    <h6>{{ "View QR Code"|t('smartlink-manager') }}</h6>
                                    <ul>
                                        <li>
                                            <a href="{{ smartLink.getQrCodeUrl() }}" target="_blank">
                                                {{ "QR Code Image"|t('smartlink-manager') }}
                                            </a>
                                        </li>
                                        <li>
                                            <a href="{{ smartLink.getQrCodeDisplayUrl() }}" target="_blank">
                                                {{ "QR Code Page"|t('smartlink-manager') }}
                                            </a>
                                        </li>
                                    </ul>
                                </li>
                                <hr>
                                <li><a id="reset-qr-defaults" href="#">{{ "Reset to Defaults"|t('smartlink-manager') }}</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </fieldset>

    {% if smartLink.id %}
        {{ smartLink.getSidebarHtml(true)|raw }}

        <dl class="meta read-only">
            <div class="data">
                <dt class="heading">{{ "ID"|t('smartlink-manager') }}</dt>
                <dd class="value">{{ smartLink.id }}</dd>
            </div>
            <div class="data">
                <dt class="heading">{{ "Status"|t('smartlink-manager') }}</dt>
                <dd class="value">
                    {% set status = smartLink.getStatus() %}
                    {% set statusColorKey = status in ['disabled', 'expired', 'pending'] ? status : 'enabled' %}
                    {% set statusLabel = {
                        enabled: 'Enabled'|t('smartlink-manager'),
                        disabled: 'Disabled'|t('smartlink-manager'),
                        expired: 'Expired'|t('smartlink-manager'),
                        pending: 'Pending'|t('smartlink-manager'),
                    }[statusColorKey] %}
                    {% include 'lindemannrock-base/_components/status-dot' with {
                        value: statusColorKey,
                        colorSet: 'status',
                    } only %}
                    <span>{{ statusLabel }}</span>
                </dd>
            </div>
    {% if canViewAnalytics and craft.smartLinks.settings.enableAnalytics and smartLink.id and (smartLink.trackAnalytics ?? true) %}
                <div class="data">
                    <dt class="heading">{{ "Interactions"|t('smartlink-manager') }}</dt>
                    <dd class="value">{{ smartLink.clicks|number }}</dd>
                </div>
            {% endif %}
            <div class="data">
                <dt class="heading">{{ "Created at"|t('smartlink-manager') }}</dt>
                <dd class="value">{{ smartLink.dateCreated|lrDatetime }}</dd>
            </div>
            <div class="data">
                <dt class="heading">{{ "Updated at"|t('smartlink-manager') }}</dt>
                <dd class="value">{{ smartLink.dateUpdated|lrDatetime }}</dd>
            </div>
        </dl>
    {% endif %}
{% endblock %}
