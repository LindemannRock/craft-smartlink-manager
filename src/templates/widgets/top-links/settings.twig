{% import "_includes/forms" as forms %}

{{ forms.selectField({
    label: 'Date Range'|t('smartlink-manager'),
    id: 'dateRange',
    name: 'dateRange',
    value: widget.dateRange,
    options: lrDateRangeOptions('assoc')
}) }}

{{ forms.selectField({
    label: 'Site'|t('smartlink-manager'),
    id: 'siteId',
    name: 'siteId',
    value: widget.siteId,
    options: siteOptions,
}) }}

{{ forms.textField({
    label: 'Number of Links'|t('smartlink-manager'),
    instructions: 'How many top links to display (1-20)'|t('smartlink-manager'),
    id: 'limit',
    name: 'limit',
    value: widget.limit,
    type: 'number',
    min: 1,
    max: 20,
    size: 3
}) }}
