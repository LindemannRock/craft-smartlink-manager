{% set plugin = craft.app.plugins.getPlugin('smartlink-manager') %}
{% set rows = [] %}

{% for link in links %}
    {% set meta %}
        {% if link.enabled %}
            {% set redirectPath = ((plugin.settings.usePrefix ?? true) ? ((plugin.settings.slugPrefix ?? 'go') ~ '/') : '') ~ link.slug %}
            <a href="{{ plugin.settings.buildPublicUrl(redirectPath, link.siteId ?? null) }}" target="_blank" rel="noopener">/{{ link.slug }}</a>
        {% else %}
            <span>/{{ link.slug }}</span>
        {% endif %}
    {% endset %}
    {% set rows = rows|merge([{
        primary: link.name,
        primaryUrl: cpUrl('smartlink-manager/smartlinks/' ~ link.id),
        metaHtml: meta,
        value: link.clicks|number,
    }]) %}
{% endfor %}

{% include 'lindemannrock-base/_components/dashboard-widget-list' with {
    primaryHeader: "Link"|t('smartlink-manager'),
    valueHeader: "Interactions"|t('smartlink-manager'),
    rows: rows,
    empty: {
        title: "No {pluginName} yet"|t('smartlink-manager', {pluginName: smartlinkHelper.pluralLowerDisplayName}),
        message: "Create your first {singularName} to see it here."|t('smartlink-manager', {singularName: smartlinkHelper.lowerDisplayName}),
    },
    footer: {
        url: cpUrl('smartlink-manager/smartlinks'),
        label: "View all {pluginName}"|t('smartlink-manager', {pluginName: smartlinkHelper.pluralLowerDisplayName}),
    },
} only %}
