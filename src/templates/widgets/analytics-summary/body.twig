{% set plugin = craft.app.plugins.getPlugin('smartlink-manager') %}

{% if data.topLinks|length > 0 %}
    {% set topLink = data.topLinks|first %}
    {% set topMeta %}
        {% if topLink.enabled is defined and topLink.enabled %}
            {% set redirectPath = ((plugin.settings.usePrefix ?? true) ? ((plugin.settings.slugPrefix ?? 'go') ~ '/') : '') ~ topLink.slug %}
            <a href="{{ plugin.settings.buildPublicUrl(redirectPath, topLink.siteId ?? null) }}" target="_blank" rel="noopener">/{{ topLink.slug }}</a>
        {% else %}
            <span>/{{ topLink.slug }}</span>
        {% endif %}
        <span class="lr-dashboard-widget-meta__separator">•</span>
        <span>{{ topLink.clicks|number }} {{ "interactions"|t('smartlink-manager') }}</span>
    {% endset %}

    {% set topItem = {
        label: "Top Performer"|t('smartlink-manager'),
        title: topLink.name,
        url: cpUrl('smartlink-manager/smartlinks/' ~ topLink.id),
        metaHtml: topMeta,
    } %}
{% else %}
    {% set topItem = null %}
{% endif %}

{% include 'lindemannrock-base/_components/dashboard-widget-stats' with {
    stats: [
        {value: data.totalClicks, label: "Total Interactions"|t('smartlink-manager')},
        {value: data.uniqueVisitors, label: "Unique Visitors"|t('smartlink-manager')},
        {value: data.activeLinks, label: "Active Links"|t('smartlink-manager')},
        {value: data.linksUsedPercentage ?? 0, suffix: '%', label: "Engagement Rate"|t('smartlink-manager')},
    ],
    topItem: topItem,
    footer: {
        url: cpUrl('smartlink-manager/analytics'),
        label: "View full analytics"|t('smartlink-manager'),
    },
} only %}
