{% extends "smartlink-manager/_layouts/settings" %}
{% set title = "Behavior Settings"|t('smartlink-manager') %}
{% set fullPageForm = true %}
{% set selectedSettingsItem = 'behavior' %}

{% set crumbs = [
    {
        label: smartlinkHelper.fullName|t('smartlink-manager'),
        url: url('smartlink-manager'),
    },
    {
        label: 'Settings'|t('smartlink-manager'),
        url: url('smartlink-manager/settings'),
    },
    {
        label: 'Behavior'|t('smartlink-manager'),
        url: url('smartlink-manager/settings/behavior'),
    },
] %}

{% import "_includes/forms" as forms %}

{% block content %}

    <form method="post" accept-charset="UTF-8">
        {{ actionInput('smartlink-manager/settings/save') }}
        {{ csrfInput() }}
        {{ redirectInput('smartlink-manager/settings/behavior') }}
        {{ hiddenInput('section', 'behavior') }}

        <h2 style="margin-top: 0px;">{{ "Redirect Behavior"|t('smartlink-manager') }}</h2>

        {{ forms.selectField({
            label: "Language Detection Method"|t('smartlink-manager'),
            instructions: "How to detect user language preference"|t('smartlink-manager'),
            id: 'languageDetectionMethod',
            name: 'settings[languageDetectionMethod]',
            value: settings.languageDetectionMethod ?? 'browser',
            options: [
                {label: 'Browser preference'|t('smartlink-manager'), value: 'browser'},
                {label: 'IP geolocation'|t('smartlink-manager'), value: 'ip'},
                {label: 'Both'|t('smartlink-manager'), value: 'both'},
            ],
            disabled: settings.isOverriddenByConfig('languageDetectionMethod'),
            warning: settings.isOverriddenByConfig('languageDetectionMethod') ?
                "This is being overridden by the <code>languageDetectionMethod</code> setting in <code>config/smartlink-manager.php</code>."|t('smartlink-manager')|raw : null,
        }) }}

        {{ forms.autosuggestField({
            label: "404 Redirect URL"|t('smartlink-manager'),
            instructions: "Where to redirect when a {singularName} is not found or disabled"|t('smartlink-manager', {singularName: smartlinkHelper.lowerDisplayName}),
            id: 'notFoundRedirectUrl',
            name: 'settings[notFoundRedirectUrl]',
            value: settings.notFoundRedirectUrl ?? '/',
            placeholder: '/',
            suggestEnvVars: true,
            errors: settings.getErrors('notFoundRedirectUrl'),
            disabled: settings.isOverriddenByConfig('notFoundRedirectUrl'),
            warning: settings.isOverriddenByConfig('notFoundRedirectUrl') ?
                "This is being overridden by the <code>notFoundRedirectUrl</code> setting in <code>config/smartlink-manager.php</code>."|t('smartlink-manager')|raw : null,
        }) }}

        <p class="light" style="margin-top: -12px; margin-bottom: 24px;">
            {{ "Can be a relative path (/) or full URL (https://example.com)"|t('smartlink-manager') }}
        </p>

    </form>

    {% include 'lindemannrock-base/_components/plugin-credit' %}
{% endblock %}
