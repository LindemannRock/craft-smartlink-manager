{% extends "smartlink-manager/_layouts/settings" %}
{% set title = "General Settings"|t('smartlink-manager') %}
{% set fullPageForm = true %}
{% set selectedSettingsItem = 'general' %}

{% set crumbs = [
    {
        label: smartlinkHelper.fullName|t('smartlink-manager'),
        url: url('smartlink-manager'),
    },
    {
        label: 'Settings'|t('smartlink-manager'),
        url: url('smartlink-manager/settings'),
    },
    {
        label: 'General'|t('smartlink-manager'),
        url: url('smartlink-manager/settings/general'),
    },
] %}

{% import "_includes/forms" as forms %}

{% block content %}

    {{ actionInput('smartlink-manager/settings/save') }}
    {{ redirectInput('smartlink-manager/settings/general') }}
    {{ hiddenInput('section', 'general') }}
    {% set smartlinkFullNameHtml = smartlinkHelper.fullName|e %}
    {% set smartlinkDisplayNameHtml = smartlinkHelper.displayName|e %}
    {% set smartlinkLowerNameHtml = smartlinkHelper.lowerDisplayName|e %}
    {% set templateStatusesBySetting = {} %}
    {% for templateStatus in templateStatuses ?? [] %}
        {% set templateStatusesBySetting = templateStatusesBySetting|merge({(templateStatus.setting): templateStatus}) %}
    {% endfor %}
    {% set smartlinkPluralLowerNameHtml = smartlinkHelper.pluralLowerDisplayName|e %}

        <h2 class="first">{{ "General Settings"|t('smartlink-manager') }}</h2>

        {% include 'lindemannrock-base/_partials/field-plugin-name' with {
            settings: settings,
            pluginHandle: 'smartlink-manager',
        } only %}

        <hr>

        <h2>{{ "Site Settings"|t('smartlink-manager') }}</h2>

        {# Site selection checkboxes #}
        {% set siteOptions = [] %}
        {% for site in craft.app.sites.getAllSites() %}
            {% set siteOptions = siteOptions|merge([{
                label: site.name,
                value: site.id
            }]) %}
        {% endfor %}

        {{ forms.checkboxGroupField({
            label: "Enabled Sites"|t('smartlink-manager'),
            instructions: "Select which sites {pluginName} should be enabled for. Leave empty to enable for all sites."|t('smartlink-manager', {pluginName: smartlinkFullNameHtml}),
            id: 'enabledSites',
            name: 'settings[enabledSites]',
            options: siteOptions,
            values: settings.enabledSites ?? [],
            disabled: settings.isOverriddenByConfig('enabledSites'),
            warning: settings.isOverriddenByConfig('enabledSites') ?
                "This is being overridden by the <code>enabledSites</code> setting in <code>config/smartlink-manager.php</code>."|t('smartlink-manager')|raw : null,
        }) }}


        <hr>

        <h2>{{ "URL Settings"|t('smartlink-manager') }}</h2>

        {% set shortlinkPluginForWarning = craft.app.plugins.getPlugin('shortlink-manager') %}
        {% set shortlinkEnabledForWarning = craft.app.plugins.isPluginEnabled('shortlink-manager') and shortlinkPluginForWarning %}
        {% set shortlinkUsePrefix = shortlinkEnabledForWarning ? (shortlinkPluginForWarning.settings.usePrefix ?? true) : true %}
        {% set shortlinkNameForWarning = shortlinkEnabledForWarning ? (shortlinkPluginForWarning.settings.pluginName ?? shortlinkPluginForWarning.name ?? 'ShortLink Manager') : 'ShortLink Manager' %}
        {% set currentUsePrefix = settings.usePrefix ?? true %}
        {% set sameHostCollision = false %}
        {% set possibleHostCollision = false %}

        {% if (not currentUsePrefix) and (not shortlinkUsePrefix) %}
            {% set currentHosts = [] %}
            {% set otherHosts = [] %}
            {% set currentUnknownHost = false %}
            {% set otherUnknownHost = false %}

            {% set smartlinkUrlSource = settings.smartlinkBaseUrl ?? '' %}
            {% if smartlinkUrlSource|trim is not empty %}
                {% if '://' in smartlinkUrlSource %}
                    {% set smartlinkHost = smartlinkUrlSource|replace({'https://': '', 'http://': ''})|split('/')|first|split(':')|first|lower %}
                    {% if smartlinkHost %}
                        {% set currentHosts = currentHosts|merge([smartlinkHost]) %}
                    {% endif %}
                {% else %}
                    {% set currentUnknownHost = true %}
                {% endif %}
            {% else %}
                {% for site in craft.app.sites.getAllSites() %}
                    {% if site.baseUrl and '://' in site.baseUrl %}
                        {% set siteHost = site.baseUrl|replace({'https://': '', 'http://': ''})|split('/')|first|split(':')|first|lower %}
                        {% if siteHost and siteHost not in currentHosts %}
                            {% set currentHosts = currentHosts|merge([siteHost]) %}
                        {% endif %}
                    {% else %}
                        {% set currentUnknownHost = true %}
                    {% endif %}
                {% endfor %}
            {% endif %}

            {% set shortlinkSettingsForWarning = shortlinkEnabledForWarning ? shortlinkPluginForWarning.settings : null %}
            {% if shortlinkSettingsForWarning %}
                {% set shortlinkUrlSource = shortlinkSettingsForWarning.shortlinkBaseUrl ?? '' %}
                {% if shortlinkUrlSource|trim is not empty %}
                    {% if '://' in shortlinkUrlSource %}
                        {% set shortlinkHost = shortlinkUrlSource|replace({'https://': '', 'http://': ''})|split('/')|first|split(':')|first|lower %}
                        {% if shortlinkHost %}
                            {% set otherHosts = otherHosts|merge([shortlinkHost]) %}
                        {% endif %}
                    {% else %}
                        {% set otherUnknownHost = true %}
                    {% endif %}
                {% else %}
                    {% for site in craft.app.sites.getAllSites() %}
                        {% if site.baseUrl and '://' in site.baseUrl %}
                            {% set siteHost = site.baseUrl|replace({'https://': '', 'http://': ''})|split('/')|first|split(':')|first|lower %}
                            {% if siteHost and siteHost not in otherHosts %}
                                {% set otherHosts = otherHosts|merge([siteHost]) %}
                            {% endif %}
                        {% else %}
                            {% set otherUnknownHost = true %}
                        {% endif %}
                    {% endfor %}
                {% endif %}
            {% endif %}

            {% for host in currentHosts %}
                {% if host in otherHosts %}
                    {% set sameHostCollision = true %}
                {% endif %}
            {% endfor %}

            {% if (not sameHostCollision) and (currentUnknownHost or otherUnknownHost) %}
                {% set possibleHostCollision = true %}
            {% endif %}
        {% endif %}

        {% set slugPrefixExample = '/' ~ ((settings.slugPrefix ?: 'go')|trim('/')) ~ '/$1' %}
        {% set slugTip = "Changing will break existing URLs. To migrate, redirect the old smart link prefix to the new one in your redirect tool, CDN, or server config, for example: Source '/old-prefix/*' → Destination '{destinationExample}'."|t('smartlink-manager', {
            destinationExample: slugPrefixExample,
        }) %}

        {{ forms.lightswitchField({
            label: "Use URL Prefix"|t('smartlink-manager'),
            instructions: "Enable to generate {singularName} URLs as /{prefix}/{slug}. Disable to generate root URLs as /{slug}."|t('smartlink-manager', {singularName: smartlinkLowerNameHtml, prefix: settings.slugPrefix ?: 'go', slug: 'your-link'}),
            id: 'usePrefix',
            name: 'settings[usePrefix]',
            on: settings.usePrefix ?? true,
            toggle: 'slug-prefix-field-wrapper',
            disabled: settings.isOverriddenByConfig('usePrefix'),
            warning: settings.isOverriddenByConfig('usePrefix') ?
                "This is being overridden by the <code>usePrefix</code> setting in <code>config/smartlink-manager.php</code>."|t('smartlink-manager')|raw : null,
        }) }}

        {% if sameHostCollision %}
            {% include 'lindemannrock-base/_components/info-box' with {
                type: 'warning',
                margin: 'both',
                message: "Both {smartName} and {shortName} are set to root URLs (no prefix) and share at least one host. Redirect routes can collide (e.g., <code>/slug</code>), and QR routes can also collide when both plugins use the same QR prefix (e.g., <code>/qr/slug</code>)."|t('smartlink-manager', {smartName: smartlinkFullNameHtml, shortName: shortlinkNameForWarning|e})|raw
            } %}
        {% elseif possibleHostCollision %}
            {% include 'lindemannrock-base/_components/info-box' with {
                type: 'warning',
                margin: 'both',
                message: "Both {smartName} and {shortName} are set to root URLs (no prefix). Host overlap could not be fully resolved from current settings/config, so redirect route collisions are possible. QR routes may also collide if both plugins use the same QR prefix."|t('smartlink-manager', {smartName: smartlinkFullNameHtml, shortName: shortlinkNameForWarning|e})
            } %}
        {% endif %}

        <div id="slug-prefix-field-wrapper" class="{{ not currentUsePrefix ? 'hidden' : '' }}">
            {{ forms.textField({
                label: "{singularName} URL Prefix"|t('smartlink-manager', {singularName: smartlinkHelper.displayName}),
                instructions: "The URL prefix for {pluginName} (e.g., 'go' creates /go/your-link)"|t('smartlink-manager', {pluginName: smartlinkPluralLowerNameHtml}),
                id: 'slugPrefix',
                name: 'settings[slugPrefix]',
                value: settings.slugPrefix ?? 'go',
                errors: settings.getErrors('slugPrefix'),
                placeholder: 'go',
                required: true,
                tip: slugTip,
                disabled: settings.isOverriddenByConfig('slugPrefix'),
                warning: settings.isOverriddenByConfig('slugPrefix') ?
                    "This is being overridden by the <code>slugPrefix</code> setting in <code>config/smartlink-manager.php</code>."|t('smartlink-manager')|raw : null,
            }) }}
        </div>

        {% if not currentUsePrefix %}
            {% include 'lindemannrock-base/_components/info-box' with {
                type: 'info',
                message: "URL Prefix is disabled. {singularName} URLs will be generated as root paths like <code>/your-link</code>."|t('smartlink-manager', {singularName: smartlinkDisplayNameHtml})|raw
            } %}
        {% endif %}

        {# Calculate smart default for qrPrefix if empty #}
        {% set qrPrefixValue = settings.qrPrefix %}
        {% set nestedDefault = (settings.slugPrefix ?: 'go') ~ '/qr' %}
        {% if not currentUsePrefix %}
            {% if qrPrefixValue is empty %}
                {% set qrPrefixValue = 'qr' %}
            {% endif %}
        {% elseif qrPrefixValue is empty %}
            {# Try nested pattern first (safer and more organized) #}
            {% set smartQrDefault = nestedDefault %}

            {% set shortlinkPlugin = craft.app.plugins.getPlugin('shortlink-manager') %}
            {% if shortlinkPlugin and craft.app.plugins.isPluginEnabled('shortlink-manager') %}
                {% set shortlinkSettings = shortlinkPlugin.getSettings() %}
                {% set conflictingPrefixes = [
                    shortlinkSettings.slugPrefix ?? 's',
                    shortlinkSettings.qrPrefix ?? 's/qr',
                ] %}

                {# Check if nested pattern conflicts with ShortLink Manager #}
                {% if nestedDefault in conflictingPrefixes %}
                    {# Try standalone alternatives #}
                    {% set found = false %}
                    {% for candidate in ['qr', 'gqr', 'q', 'go-qr'] %}
                        {% if not found and candidate not in conflictingPrefixes and candidate != settings.slugPrefix %}
                            {% set smartQrDefault = candidate %}
                            {% set found = true %}
                        {% endif %}
                    {% endfor %}
                {% endif %}
            {% endif %}

            {% set qrPrefixValue = smartQrDefault %}
        {% endif %}

        {% set qrPrefixExample = '/' ~ (qrPrefixValue|trim('/')) ~ '/$1' %}
        {% set qrTip = "Changing will break existing QR URLs. To migrate, redirect the old QR prefix to the new one in your redirect tool, CDN, or server config, for example: Source '/old-qr-prefix/*' → Destination '{destinationExample}'. Supports standalone (e.g., 'qr') or nested (e.g., 'go/qr') patterns."|t('smartlink-manager', {
            destinationExample: qrPrefixExample,
        }) %}

        {{ forms.textField({
            label: "QR Code URL Prefix"|t('smartlink-manager'),
            instructions: "The URL prefix for QR code pages (e.g., 'qr' creates /qr/your-link/view or 'go/qr' creates /go/qr/your-link/view)"|t('smartlink-manager'),
            id: 'qrPrefix',
            name: 'settings[qrPrefix]',
            value: qrPrefixValue,
            errors: settings.getErrors('qrPrefix'),
            placeholder: currentUsePrefix ? nestedDefault : 'qr',
            required: true,
            tip: qrTip,
            disabled: settings.isOverriddenByConfig('qrPrefix'),
            warning: settings.isOverriddenByConfig('qrPrefix') ?
                "This is being overridden by the <code>qrPrefix</code> setting in <code>config/smartlink-manager.php</code>."|t('smartlink-manager')|raw : null,
        }) }}

        {{ forms.autosuggestField({
            label: "{singularName} Base URL"|t('smartlink-manager', {singularName: smartlinkHelper.displayName}),
            instructions: "Base URL for {singularName} and QR code URLs. For multisite, you can use tokens: {siteHandle}, {siteId}, {siteUid} (e.g., https://go.example.com/{siteHandle}). Leave empty to use each site's base URL."|t('smartlink-manager', {singularName: smartlinkLowerNameHtml, siteHandle: '{siteHandle}'}),
            id: 'smartlinkBaseUrl',
            name: 'settings[smartlinkBaseUrl]',
            value: settings.smartlinkBaseUrl ?? '',
            errors: settings.getErrors('smartlinkBaseUrl'),
            placeholder: 'https://go.example.com',
            suggestEnvVars: true,
            disabled: settings.isOverriddenByConfig('smartlinkBaseUrl'),
            warning: settings.isOverriddenByConfig('smartlinkBaseUrl') ?
                "This is being overridden by the <code>smartlinkBaseUrl</code> setting in <code>config/smartlink-manager.php</code>."|t('smartlink-manager')|raw : null,
        }) }}

        {% set hasMultipleSites = craft.app.sites.getAllSites()|length > 1 %}
        {% set smartlinkBaseUrlValue = settings.smartlinkBaseUrl ?? '' %}
        {% set hasSiteToken = '{siteHandle}' in smartlinkBaseUrlValue or '{siteId}' in smartlinkBaseUrlValue or '{siteUid}' in smartlinkBaseUrlValue %}
        {% if hasMultipleSites and smartlinkBaseUrlValue|trim is not empty and not hasSiteToken %}
            {% include 'lindemannrock-base/_components/info-box' with {
                type: 'warning',
                message: "Multisite detected: <code>{singularName} Base URL</code> is set without a site token. Generated URLs may resolve to only one site. Use a tokenized URL like <code>https://go.example.com/{siteHandle}</code> to preserve site-specific routing."|t('smartlink-manager', {singularName: smartlinkDisplayNameHtml, siteHandle: '{siteHandle}'})|raw
            } %}
        {% endif %}

        <hr>

        <h2>{{ "Template Settings"|t('smartlink-manager') }}</h2>

        {% include 'lindemannrock-base/_components/info-box' with {
            type: 'info',
            message: "These templates must exist in your site's <code>templates/</code> folder at the paths configured below. Copy each matching reference template into its configured destination and customize as needed."|t('smartlink-manager')
        } %}

        {% set redirectTemplateStatus = templateStatusesBySetting.redirectTemplate ?? null %}
        {{ forms.autosuggestField({
            label: "Redirect Template"|t('smartlink-manager'),
            instructions: "Template path in your templates/ folder. Leave empty to use the default path."|t('smartlink-manager'),
            id: 'redirectTemplate',
            name: 'settings[redirectTemplate]',
            value: settings.redirectTemplate ?? '',
            placeholder: 'smartlink-manager/redirect',
            suggestEnvVars: true,
            disabled: settings.isOverriddenByConfig('redirectTemplate'),
            warning: settings.isOverriddenByConfig('redirectTemplate') ?
                "This is being overridden by the <code>redirectTemplate</code> setting in <code>config/smartlink-manager.php</code>."|t('smartlink-manager')|raw : null,
            errors: settings.getErrors('redirectTemplate')
        }) }}

        {% if redirectTemplateStatus %}
            <p class="light" style="margin-top: -12px; margin-bottom: 24px;">
                {{ "Required: copy <code>{source}</code> to <code>{destination}</code>"|t('smartlink-manager', {
                    source: redirectTemplateStatus.source|e,
                    destination: redirectTemplateStatus.destination|e,
                })|raw }}
            </p>
        {% endif %}

        {% set qrTemplateStatus = templateStatusesBySetting.qrTemplate ?? null %}
        {{ forms.autosuggestField({
            label: "QR Code Template"|t('smartlink-manager'),
            instructions: "Template path in your templates/ folder. Leave empty to use the default path."|t('smartlink-manager'),
            id: 'qrTemplate',
            name: 'settings[qrTemplate]',
            value: settings.qrTemplate ?? '',
            placeholder: 'smartlink-manager/qr',
            suggestEnvVars: true,
            disabled: settings.isOverriddenByConfig('qrTemplate'),
            warning: settings.isOverriddenByConfig('qrTemplate') ?
                "This is being overridden by the <code>qrTemplate</code> setting in <code>config/smartlink-manager.php</code>."|t('smartlink-manager')|raw : null,
            errors: settings.getErrors('qrTemplate')
        }) }}

        {% if qrTemplateStatus %}
            <p class="light" style="margin-top: -12px; margin-bottom: 24px;">
                {{ "Required: copy <code>{source}</code> to <code>{destination}</code>"|t('smartlink-manager', {
                    source: qrTemplateStatus.source|e,
                    destination: qrTemplateStatus.destination|e,
                })|raw }}
            </p>
        {% endif %}

        <hr>

        <h2>{{ "Asset Settings"|t('smartlink-manager') }}</h2>

        {# Asset volume selection dropdown for Smart Link images #}
        {% set volumeOptions = [{label: 'All asset volumes'|t('smartlink-manager'), value: ''}] %}
        {% for volume in craft.app.volumes.getAllVolumes() %}
            {% set volumeOptions = volumeOptions|merge([{
                label: volume.name,
                value: volume.uid
            }]) %}
        {% endfor %}

        {{ forms.selectField({
            label: "{singularName} Image Volume"|t('smartlink-manager', {singularName: smartlinkHelper.displayName}),
            instructions: "Which asset volume should be used for {singularName} images"|t('smartlink-manager', {singularName: smartlinkDisplayNameHtml}),
            id: 'imageVolumeUid',
            name: 'settings[imageVolumeUid]',
            options: volumeOptions,
            value: settings.imageVolumeUid ?? '',
            disabled: settings.isOverriddenByConfig('imageVolumeUid'),
            warning: settings.isOverriddenByConfig('imageVolumeUid') ?
                "This is being overridden by the <code>imageVolumeUid</code> setting in <code>config/smartlink-manager.php</code>."|t('smartlink-manager')|raw : null,
        }) }}

        <hr>

        <h2>{{ "Logging Settings"|t('smartlink-manager') }}</h2>

        {% include 'lindemannrock-base/_partials/field-log-level' with {
            settings: settings,
            pluginHandle: 'smartlink-manager',
        } only %}

    {% include 'lindemannrock-base/_components/plugin-credit' %}
{% endblock %}
