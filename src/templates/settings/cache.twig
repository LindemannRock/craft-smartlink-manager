{% extends "smartlink-manager/_layouts/settings" %}
{% set title = "Cache Settings"|t('smartlink-manager') %}
{% set fullPageForm = true %}
{% set selectedSettingsItem = 'cache' %}

{% set crumbs = [
    {
        label: smartlinkHelper.fullName|t('smartlink-manager'),
        url: url('smartlink-manager'),
    },
    {
        label: 'Settings'|t('smartlink-manager'),
        url: url('smartlink-manager/settings'),
    },
    {
        label: 'Cache'|t('smartlink-manager'),
        url: url('smartlink-manager/settings/cache'),
    },
] %}

{% import "_includes/forms" as forms %}

{% block content %}

    <form method="post" accept-charset="UTF-8">
        {{ actionInput('smartlink-manager/settings/save') }}
        {{ csrfInput() }}
        {{ redirectInput('smartlink-manager/settings/cache') }}
        {{ hiddenInput('section', 'cache') }}

        <h2 style="margin-top: 0px;">{{ "Cache Storage Settings"|t('smartlink-manager') }}</h2>

        {{ forms.selectField({
            label: 'Cache Storage Method'|t('smartlink-manager'),
            instructions: 'How to store cache data. Use Redis/Database for load-balanced or multi-server environments.'|t('smartlink-manager'),
            id: 'cacheStorageMethod',
            name: 'settings[cacheStorageMethod]',
            value: settings.cacheStorageMethod ?? 'file',
            options: [
                { value: 'file', label: 'File System (default, single server)'|t('smartlink-manager') },
                { value: 'redis', label: 'Redis/Database (load-balanced, multi-server, cloud hosting)'|t('smartlink-manager') },
            ],
            disabled: settings.isOverriddenByConfig('cacheStorageMethod'),
            warning: settings.isOverriddenByConfig('cacheStorageMethod') ?
                "This is being overridden by the <code>cacheStorageMethod</code> setting in <code>config/smartlink-manager.php</code>."|t('smartlink-manager')|raw : null,
        }) }}

        {% set craftUsesRedis = craft.app.cache is defined and craft.app.cache.className is defined and craft.app.cache.className == 'yii\\redis\\Cache' %}

        <div id="cache-location-file" class="{{ (settings.cacheStorageMethod ?? 'file') == 'redis' ? 'hidden' }}">
            {% include 'lindemannrock-base/_components/info-box' with {
                message: '<strong>' ~ 'Cache Location'|t('smartlink-manager') ~ ':</strong> <code>' ~ smartlinkHelper.cacheBasePath ~ '</code>',
                type: 'info'
            } %}
        </div>

        <div id="cache-location-redis" class="{{ (settings.cacheStorageMethod ?? 'file') == 'file' ? 'hidden' }}">
            {% if craftUsesRedis %}
                {% include 'lindemannrock-base/_components/info-box' with {
                    type: 'success',
                    message: '<strong>' ~ 'Cache Location'|t('smartlink-manager') ~ ':</strong> ' ~ "Using Craft's configured Redis cache from <code>config/app.php</code>"|t('smartlink-manager')
                } %}
            {% else %}
                {% include 'lindemannrock-base/_components/info-box' with {
                    type: 'warning',
                    message: '<strong>' ~ 'Redis Not Configured'|t('smartlink-manager') ~ ':</strong> ' ~ "To use Redis caching, install <code>yiisoft/yii2-redis</code> and configure it in <code>config/app.php</code>."|t('smartlink-manager') ~ ' <a href="https://craftcms.com/docs/5.x/reference/config/app.html#cache" target="_blank" rel="noopener">' ~ 'Learn more'|t('smartlink-manager') ~ '</a>'
                } %}
            {% endif %}
        </div>

        <hr>

        <h2>{{ "QR Code Caching"|t('smartlink-manager') }}</h2>

        {{ forms.lightswitchField({
            label: "Enable QR Code Cache"|t('smartlink-manager'),
            instructions: "Cache generated QR codes for better performance"|t('smartlink-manager'),
            id: 'enableQrCodeCache',
            name: 'settings[enableQrCodeCache]',
            on: settings.enableQrCodeCache ?? true,
            toggle: 'qr-cache-settings',
            disabled: settings.isOverriddenByConfig('enableQrCodeCache'),
            warning: settings.isOverriddenByConfig('enableQrCodeCache') ?
                "This is being overridden by the <code>enableQrCodeCache</code> setting in <code>config/smartlink-manager.php</code>."|t('smartlink-manager')|raw : null,
        }) }}

        <div id="qr-cache-settings" class="{{ not (settings.enableQrCodeCache ?? true) ? 'hidden' }}">
            {{ forms.textField({
                label: "QR Code Cache Duration"|t('smartlink-manager'),
                instructions: ('Cache duration in seconds. Current:'|t('smartlink-manager') ~ ' <strong id="qrCodeCacheDuration-human"></strong>')|raw,
                id: 'qrCodeCacheDuration',
                name: 'settings[qrCodeCacheDuration]',
                value: settings.qrCodeCacheDuration ?? 86400,
                type: 'number',
                min: 60,
                max: 604800,
                tip: 'Min: 60 (1 minute), Max: 604800 (7 days)'|t('smartlink-manager'),
                errors: settings.getErrors('qrCodeCacheDuration'),
                disabled: settings.isOverriddenByConfig('qrCodeCacheDuration'),
                warning: settings.isOverriddenByConfig('qrCodeCacheDuration') ?
                    "This is being overridden by the <code>qrCodeCacheDuration</code> setting in <code>config/smartlink-manager.php</code>."|t('smartlink-manager')|raw : null,
            }) }}
        </div>

        {% if settings.enableAnalytics ?? true %}
            <hr>

            <h2>{{ "Device Detection Caching"|t('smartlink-manager') }}</h2>

            {{ forms.lightswitchField({
                label: "Cache Device Detection"|t('smartlink-manager'),
                instructions: "Cache device detection results for better performance"|t('smartlink-manager'),
                id: 'cacheDeviceDetection',
                name: 'settings[cacheDeviceDetection]',
                on: settings.cacheDeviceDetection ?? true,
                toggle: 'device-cache-settings',
                disabled: settings.isOverriddenByConfig('cacheDeviceDetection'),
                warning: settings.isOverriddenByConfig('cacheDeviceDetection') ?
                    "This is being overridden by the <code>cacheDeviceDetection</code> setting in <code>config/smartlink-manager.php</code>."|t('smartlink-manager')|raw : null,
            }) }}

            <div id="device-cache-settings" class="{{ not (settings.cacheDeviceDetection ?? true) ? 'hidden' }}">
                {{ forms.textField({
                    label: "Device Detection Cache Duration"|t('smartlink-manager'),
                    instructions: ('Cache duration in seconds. Current:'|t('smartlink-manager') ~ ' <strong id="deviceDetectionCacheDuration-human"></strong>')|raw,
                    id: 'deviceDetectionCacheDuration',
                    name: 'settings[deviceDetectionCacheDuration]',
                    value: settings.deviceDetectionCacheDuration ?? 3600,
                    type: 'number',
                    min: 60,
                    max: 604800,
                    tip: 'Min: 60 (1 minute), Max: 604800 (7 days)'|t('smartlink-manager'),
                    errors: settings.getErrors('deviceDetectionCacheDuration'),
                    disabled: settings.isOverriddenByConfig('deviceDetectionCacheDuration'),
                    warning: settings.isOverriddenByConfig('deviceDetectionCacheDuration') ?
                        "This is being overridden by the <code>deviceDetectionCacheDuration</code> setting in <code>config/smartlink-manager.php</code>."|t('smartlink-manager')|raw : null,
                }) }}

                {% include 'lindemannrock-base/_components/info-box' with {
                    message: '<strong>' ~ 'How it works'|t('smartlink-manager') ~ ':</strong><br>'
                        ~ '• ' ~ 'Device detection parses user-agent strings to identify devices, browsers, and operating systems'|t('smartlink-manager') ~ '<br>'
                        ~ '• ' ~ 'Results are cached to avoid re-parsing the same user-agent repeatedly'|t('smartlink-manager') ~ '<br>'
                        ~ '• ' ~ 'Recommended to keep enabled for production sites'|t('smartlink-manager')
                } %}
            </div>
        {% else %}
            <hr>

            <h2>{{ "Device Detection Caching"|t('smartlink-manager') }}</h2>

            <div class="field">
                <p class="light" style="color: #999;">
                    {{ "Device detection caching is only available when Analytics is enabled. Go to"|t('smartlink-manager') }}
                    <a href="{{ url('smartlink-manager/settings/analytics') }}">{{ "Analytics Settings"|t('smartlink-manager') }}</a>
                    {{ "to enable analytics."|t('smartlink-manager') }}
                </p>
            </div>
        {% endif %}

    </form>

    {% include 'lindemannrock-base/_components/plugin-credit' %}
{% endblock %}

{% js %}
// Toggle cache location info boxes based on storage method selection
$('#cacheStorageMethod').on('change', function() {
    const value = $(this).val();
    if (value === 'redis') {
        $('#cache-location-file').addClass('hidden');
        $('#cache-location-redis').removeClass('hidden');
    } else {
        $('#cache-location-redis').addClass('hidden');
        $('#cache-location-file').removeClass('hidden');
    }
});

// Convert seconds to human-readable duration
var _timeUnits = {
    second: {{ '{count} second'|t('smartlink-manager', {count: '__COUNT__'})|json_encode|raw }},
    seconds: {{ '{count} seconds'|t('smartlink-manager', {count: '__COUNT__'})|json_encode|raw }},
    minute: {{ '{count} minute'|t('smartlink-manager', {count: '__COUNT__'})|json_encode|raw }},
    minutes: {{ '{count} minutes'|t('smartlink-manager', {count: '__COUNT__'})|json_encode|raw }},
    hour: {{ '{count} hour'|t('smartlink-manager', {count: '__COUNT__'})|json_encode|raw }},
    hours: {{ '{count} hours'|t('smartlink-manager', {count: '__COUNT__'})|json_encode|raw }},
    day: {{ '{count} day'|t('smartlink-manager', {count: '__COUNT__'})|json_encode|raw }},
    days: {{ '{count} days'|t('smartlink-manager', {count: '__COUNT__'})|json_encode|raw }}
};
function secondsToHuman(seconds) {
    seconds = parseInt(seconds) || 0;
    if (seconds < 60) {
        return _timeUnits[seconds !== 1 ? 'seconds' : 'second'].replace('__COUNT__', seconds);
    } else if (seconds < 3600) {
        var mins = Math.round(seconds / 60 * 10) / 10;
        return _timeUnits[mins !== 1 ? 'minutes' : 'minute'].replace('__COUNT__', mins);
    } else if (seconds < 86400) {
        var hours = Math.round(seconds / 3600 * 10) / 10;
        return _timeUnits[hours !== 1 ? 'hours' : 'hour'].replace('__COUNT__', hours);
    } else {
        var days = Math.round(seconds / 86400 * 10) / 10;
        return _timeUnits[days !== 1 ? 'days' : 'day'].replace('__COUNT__', days);
    }
}

// Update human-readable duration on input change
$('#qrCodeCacheDuration').on('input', function() {
    $('#qrCodeCacheDuration-human').text(secondsToHuman($(this).val()));
});

$('#deviceDetectionCacheDuration').on('input', function() {
    $('#deviceDetectionCacheDuration-human').text(secondsToHuman($(this).val()));
});

// Initialize on page load
$('#qrCodeCacheDuration-human').text(secondsToHuman($('#qrCodeCacheDuration').val()));
$('#deviceDetectionCacheDuration-human').text(secondsToHuman($('#deviceDetectionCacheDuration').val()));
{% endjs %}
