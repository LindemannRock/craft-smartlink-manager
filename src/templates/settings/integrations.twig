{% extends "smartlink-manager/_layouts/settings" %}
{% set title = "Integrations Settings"|t('smartlink-manager') %}
{% set fullPageForm = true %}
{% set selectedSettingsItem = 'integrations' %}

{% set crumbs = [
    {
        label: smartlinkHelper.fullName|t('smartlink-manager'),
        url: url('smartlink-manager'),
    },
    {
        label: 'Settings'|t('smartlink-manager'),
        url: url('smartlink-manager/settings'),
    },
    {
        label: 'Integrations'|t('smartlink-manager'),
        url: url('smartlink-manager/settings/integrations'),
    },
] %}

{% import "_includes/forms" as forms %}

{% block content %}

    {{ actionInput('smartlink-manager/settings/save') }}
    {{ redirectInput('smartlink-manager/settings/integrations') }}
    {{ hiddenInput('section', 'integrations') }}

        <h2 class="first">{{ "Third-Party Integrations"|t('smartlink-manager') }}</h2>

        <div class="field">
            <p class="light">{{ "Integrate {pluginName} with third-party analytics and tracking services to push click events to Google Tag Manager, Google Analytics, and other platforms."|t('smartlink-manager', { pluginName: smartlinkHelper.fullName }) }}</p>
        </div>

        {% set integrationStatuses = craft.app.plugins.getPlugin('smartlink-manager').integration.getAllIntegrationStatuses() %}

        {# SEOmatic Integration #}
        {% set seomaticStatus = integrationStatuses.seomatic ?? null %}
        {% set seomaticInstalled = lrPluginInstalled('seomatic') %}
        {% set seomaticAvailable = lrPluginEnabled('seomatic') %}
        {% set seomaticPluginName = lrPluginName('seomatic', 'SEOmatic') %}
        {% set seomaticEnabled = 'seomatic' in (settings.enabledIntegrations ?? []) %}

        {% embed 'lindemannrock-base/_partials/integration-card' with {
            title: "{pluginName} Integration"|t('smartlink-manager', { pluginName: seomaticPluginName }),
            description: "Push {smartLinksName} click events to Google Tag Manager and analytics platforms for tracking redirects, button clicks, and QR code scans."|t('smartlink-manager', { smartLinksName: smartlinkHelper.lowerDisplayName }),
            available: seomaticAvailable,
            installed: seomaticInstalled,
            installUrl: 'https://plugins.craftcms.com/seomatic',
            statusLabels: {
                active: 'Installed & Active'|t('smartlink-manager'),
                disabled: 'Installed but Disabled'|t('smartlink-manager'),
                notInstalled: 'Not Installed'|t('smartlink-manager'),
                install: 'Install Plugin'|t('smartlink-manager'),
            },
            toggleId: 'enableSeomaticIntegration',
            toggleName: 'enableSeomaticIntegration',
            toggleOn: seomaticEnabled,
            toggleDisabled: not seomaticAvailable or settings.isOverriddenByConfig('enabledIntegrations'),
            bodyId: 'seomatic-settings',
            bodyVisible: seomaticEnabled,
        } %}
            {% block body %}
                {% import "_includes/forms" as forms %}

                {% if settings.isOverriddenByConfig('enabledIntegrations') %}
                    <p class="warning has-icon lr-config-override-note">
                        <span class="icon" aria-hidden="true"></span>
                        <span>{{ "This is being overridden by the <code>enabledIntegrations</code> setting in <code>config/smartlink-manager.php</code>."|t('smartlink-manager')|raw }}</span>
                    </p>
                {% endif %}

                {# Active Tracking Scripts - Only show GTM and GA4 (scripts that receive dataLayer events) #}
                {% set dataLayerScripts = ['googleTagManager', 'gtag'] %}
                {% set hasDataLayerScripts = false %}
                {% for handle in dataLayerScripts %}
                    {% if seomaticStatus.scripts[handle] is defined %}
                        {% set hasDataLayerScripts = true %}
                    {% endif %}
                {% endfor %}

                {% if hasDataLayerScripts %}
                    <div class="lr-integration-scripts">
                        <div class="lr-integration-scripts__heading">
                            <strong>{{ "Active Tracking Scripts"|t('smartlink-manager') }}</strong>
                            <span class="light">{{ "Scripts receiving {pluginName} events"|t('smartlink-manager', { pluginName: smartlinkHelper.fullName }) }}</span>
                        </div>
                        {% for handle in dataLayerScripts %}
                            {% if seomaticStatus.scripts[handle] is defined %}
                                {% set script = seomaticStatus.scripts[handle] %}
                                <div class="lr-integration-scripts__item">
                                    <div class="lr-integration-scripts__name">
                                        {% include 'lindemannrock-base/_components/status-dot' with {
                                            status: 'enabled',
                                            size: 8,
                                        } only %}
                                        <strong>{{ script.name }}</strong>
                                    </div>
                                    {% if script.sites is defined and script.sites is not empty %}
                                        <div class="lr-integration-scripts__sites">
                                            {% for site in script.sites %}
                                                <div class="lr-integration-scripts__site">
                                                    <strong>{{ site.name }}</strong>
                                                    {% if site.id is defined and site.id %}
                                                        <code>{{ site.id }}</code>
                                                    {% endif %}
                                                </div>
                                            {% endfor %}
                                        </div>
                                    {% endif %}
                                </div>
                            {% endif %}
                        {% endfor %}
                    </div>

                {% else %}
                    {% include 'lindemannrock-base/_components/info-box' with {
                        type: 'warning',
                        variant: 'colored',
                        margin: 'bottom',
                        message: '<strong>' ~ "Note"|t('smartlink-manager') ~ ':</strong> ' ~ "No tracking scripts are currently configured in {pluginName}. Events will be queued but not sent until you configure GTM or Google Analytics in {pluginName}."|t('smartlink-manager', { pluginName: seomaticPluginName })
                    } %}
                {% endif %}

                {# Configuration Section #}
                <div class="lr-integration-section">
                    <h4 class="lr-integration-section__title">{{ "Configuration"|t('smartlink-manager') }}</h4>

                    {# Event Type Selection - Lightswitch Toggles #}
                    {% set trackingEvents = settings.seomaticTrackingEvents ?? ['redirect', 'button_click', 'qr_scan'] %}
                    {% set isOverridden = settings.isOverriddenByConfig('seomaticTrackingEvents') %}

                    <div class="field">
                        <div class="heading">
                            <label>{{ "Tracking Events"|t('smartlink-manager') }}</label>
                            <div class="instructions">
                                <p>{{ "Select which events to send to {pluginName}"|t('smartlink-manager', { pluginName: seomaticPluginName }) }}</p>
                            </div>
                        </div>

                        {% if isOverridden %}
                            <p class="warning has-icon lr-config-override-note">
                                <span class="icon" aria-hidden="true"></span>
                                <span>{{ "This is being overridden by the <code>seomaticTrackingEvents</code> setting in <code>config/smartlink-manager.php</code>."|t('smartlink-manager')|raw }}</span>
                            </p>
                        {% endif %}

                        <div class="lr-option-rows">
                            {# Auto-Redirects #}
                            <div class="lr-option-row">
                                <div class="lr-flex-none">
                                    {{ forms.lightswitchField({
                                        label: false,
                                        id: 'seomaticTrackingEvents-redirect',
                                        name: 'settings[seomaticTrackingEvents][]',
                                        value: 'redirect',
                                        on: 'redirect' in trackingEvents,
                                        disabled: isOverridden,
                                    }) }}
                                </div>
                                <div>
                                    <strong>{{ "Auto-Redirects"|t('smartlink-manager') }}</strong>
                                    <span class="light lr-option-row__desc">{{ "Mobile users automatically redirected"|t('smartlink-manager') }}</span>
                                </div>
                            </div>

                            {# Button Clicks #}
                            <div class="lr-option-row">
                                <div class="lr-flex-none">
                                    {{ forms.lightswitchField({
                                        label: false,
                                        id: 'seomaticTrackingEvents-button_click',
                                        name: 'settings[seomaticTrackingEvents][]',
                                        value: 'button_click',
                                        on: 'button_click' in trackingEvents,
                                        disabled: isOverridden,
                                    }) }}
                                </div>
                                <div>
                                    <strong>{{ "Button Clicks"|t('smartlink-manager') }}</strong>
                                    <span class="light lr-option-row__desc">{{ "Manual platform selection on landing page"|t('smartlink-manager') }}</span>
                                </div>
                            </div>

                            {# QR Code Scans #}
                            <div class="lr-option-row">
                                <div class="lr-flex-none">
                                    {{ forms.lightswitchField({
                                        label: false,
                                        id: 'seomaticTrackingEvents-qr_scan',
                                        name: 'settings[seomaticTrackingEvents][]',
                                        value: 'qr_scan',
                                        on: 'qr_scan' in trackingEvents,
                                        disabled: isOverridden,
                                    }) }}
                                </div>
                                <div>
                                    <strong>{{ "QR Code Scans"|t('smartlink-manager') }}</strong>
                                    <span class="light lr-option-row__desc">{{ "QR code accessed via ?src=qr parameter"|t('smartlink-manager') }}</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    {# Event Prefix #}
                    {{ forms.textField({
                        label: "Event Prefix"|t('smartlink-manager'),
                        instructions: "Prefix for event names (e.g., 'smart_links_redirect')"|t('smartlink-manager'),
                        id: 'seomaticEventPrefix',
                        name: 'settings[seomaticEventPrefix]',
                        value: settings.seomaticEventPrefix ?? 'smart_links',
                        placeholder: 'smart_links',
                        disabled: settings.isOverriddenByConfig('seomaticEventPrefix'),
                        warning: settings.isOverriddenByConfig('seomaticEventPrefix') ?
                            "This is being overridden by the <code>seomaticEventPrefix</code> setting in <code>config/smartlink-manager.php</code>."|t('smartlink-manager')|raw : null,
                        errors: (settings is defined and settings) ? settings.getErrors('seomaticEventPrefix') : []
                    }) }}
                </div>

                {# Event Structure Documentation - Collapsible #}
                <details class="lr-integration-details">
                    <summary>
                        {{ "Event Data Structure"|t('smartlink-manager') }}
                        <span class="light">{{ "Click to view the data layer event format"|t('smartlink-manager') }}</span>
                    </summary>
                    <div class="lr-code-block">
<pre>{
  event: "smart_links_redirect",
  smart_link: {
    slug: "promo-2024",
    title: "Summer Promo",
    destination_url: "https://app.example.com",
    platform: "ios",
    source: "qr",
    device_type: "mobile",
    os: "iOS 17",
    browser: "Safari",
    country: "United States",
    city: "New York",
    click_type: "button"
  }
}</pre>
                    </div>
                </details>

                {# Help Text #}
                {% include 'lindemannrock-base/_components/info-box' with {
                    type: 'info',
                    variant: 'colored',
                    margin: 'none',
                    message: '<strong>' ~ "How Events Are Sent"|t('smartlink-manager') ~ ':</strong>
                        <ul class="lr-integration-help-list">
                            <li>
                                <strong>' ~ "{pluginName} pushes events to GTM or GA4 dataLayer only"|t('smartlink-manager', {pluginName: smartlinkHelper.fullName}) ~ '</strong><br>
                                <span class="light">' ~ "Only Google Tag Manager and Google Analytics 4 support the dataLayer format in SEOmatic"|t('smartlink-manager') ~ '</span>
                            </li>
                            <li>
                                <strong>' ~ "Use GTM to forward to other platforms"|t('smartlink-manager') ~ '</strong><br>
                                <span class="light">' ~ "Configure GTM triggers and tags to forward {pluginName} events to Facebook Pixel, LinkedIn, HubSpot, etc."|t('smartlink-manager', {pluginName: smartlinkHelper.fullName}) ~ '</span>
                            </li>
                            <li>
                                <span class="light">' ~ "Events are only sent when analytics tracking is enabled both globally and per-link"|t('smartlink-manager') ~ '</span>
                            </li>
                        </ul>
                        <p class="lr-integration-help-note">
                            <strong>' ~ "Architecture"|t('smartlink-manager') ~ ':</strong>
                            ' ~ smartlinkHelper.fullName ~ ' → GTM/GA4 dataLayer → GTM Triggers → Facebook/LinkedIn/HubSpot/etc.
                        </p>'
                } %}
            {% endblock %}
        {% endembed %}

        {# Redirect Manager Integration #}
        {% set rmInstalled = lrPluginInstalled('redirect-manager') %}
        {% set rmAvailable = lrPluginEnabled('redirect-manager') %}
        {% set rmPluginName = lrPluginName('redirect-manager', 'Redirect Manager') %}
        {% set rmIntegrationEnabled = 'redirect-manager' in (settings.enabledIntegrations ?? []) %}
        {% set rmEvents = settings.redirectManagerEvents ?? ['slug-change'] %}

        {% embed 'lindemannrock-base/_partials/integration-card' with {
            title: "{pluginName} Integration"|t('smartlink-manager', { pluginName: rmPluginName }),
            description: "Create permanent redirect records when {pluginName} slugs change. Provides centralized redirect management and analytics tracking."|t('smartlink-manager', {pluginName: smartlinkHelper.lowerDisplayName}),
            available: rmAvailable,
            installed: rmInstalled,
            installUrl: 'https://github.com/LindemannRock/craft-redirect-manager',
            statusLabels: {
                active: 'Installed & Active'|t('smartlink-manager'),
                disabled: 'Installed but Disabled'|t('smartlink-manager'),
                notInstalled: 'Not Installed'|t('smartlink-manager'),
                install: 'Install Plugin'|t('smartlink-manager'),
            },
            toggleId: 'enableRedirectManagerIntegration',
            toggleName: 'enableRedirectManagerIntegration',
            toggleOn: rmIntegrationEnabled,
            toggleDisabled: not rmAvailable or settings.isOverriddenByConfig('enabledIntegrations'),
            bodyId: 'redirect-manager-settings',
            bodyVisible: rmIntegrationEnabled,
        } %}
            {% block body %}
                {% import "_includes/forms" as forms %}

                {% if settings.isOverriddenByConfig('enabledIntegrations') %}
                    <p class="warning has-icon lr-config-override-note">
                        <span class="icon" aria-hidden="true"></span>
                        <span>{{ "This is being overridden by the <code>enabledIntegrations</code> setting in <code>config/smartlink-manager.php</code>."|t('smartlink-manager')|raw }}</span>
                    </p>
                {% endif %}

                {# Configuration Section #}
                <div class="lr-integration-section">
                    <h4 class="lr-integration-section__title">{{ "Configuration"|t('smartlink-manager') }}</h4>

                    {% set isOverridden = settings.isOverriddenByConfig('redirectManagerEvents') %}

                    <div class="field">
                        <div class="heading">
                            <label>{{ "Automatic Redirect Creation"|t('smartlink-manager') }}</label>
                            <div class="instructions">
                                <p>{{ "Select which events should create permanent redirects in {pluginName}"|t('smartlink-manager', { pluginName: rmPluginName }) }}</p>
                            </div>
                        </div>

                        {% if isOverridden %}
                            <p class="warning has-icon lr-config-override-note">
                                <span class="icon" aria-hidden="true"></span>
                                <span>{{ "This is being overridden by the <code>redirectManagerEvents</code> setting in <code>config/smartlink-manager.php</code>."|t('smartlink-manager')|raw }}</span>
                            </p>
                        {% endif %}

                        <div class="lr-option-rows">
                            {# Slug Changes #}
                            <div class="lr-option-row">
                                <div class="lr-flex-none">
                                    {{ forms.lightswitchField({
                                        label: false,
                                        id: 'redirectManagerEvents-slug-change',
                                        name: 'settings[redirectManagerEvents][]',
                                        value: 'slug-change',
                                        on: 'slug-change' in rmEvents,
                                        disabled: isOverridden,
                                    }) }}
                                </div>
                                <div>
                                    <strong>{{ "Slug Changes"|t('smartlink-manager') }}</strong>
                                    <span class="light lr-option-row__desc">{{ "Change slug from <code>promo-2024</code> to <code>promo-2025</code> → Creates <code>/go/promo-2024</code> → <code>/go/promo-2025</code>"|t('smartlink-manager')|raw }}</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                {# Help Text #}
                {% include 'lindemannrock-base/_components/info-box' with {
                    type: 'info',
                    variant: 'colored',
                    margin: 'none',
                    message: '<strong>' ~ "Benefits of This Integration"|t('smartlink-manager') ~ ':</strong>
                        <ul class="lr-integration-help-list lr-integration-help-list--flush">
                            <li>
                                <strong>' ~ "Centralized Management"|t('smartlink-manager') ~ '</strong> –
                                ' ~ "View and manage all redirects ({pluginName} + regular pages) in one place"|t('smartlink-manager', {pluginName: smartlinkHelper.pluralLowerDisplayName}) ~ '
                            </li>
                            <li>
                                <strong>' ~ "Analytics Tracking"|t('smartlink-manager') ~ '</strong> –
                                ' ~ "See how many people try to access deleted or changed {pluginName}, their devices, browsers, and countries"|t('smartlink-manager', {pluginName: smartlinkHelper.pluralLowerDisplayName}) ~ '
                            </li>
                            <li>
                                <strong>' ~ "Persistent Redirects"|t('smartlink-manager') ~ '</strong> –
                                ' ~ "Redirects persist even if {pluginName} is deleted, preventing broken links permanently"|t('smartlink-manager', {pluginName: smartlinkHelper.lowerDisplayName}) ~ '
                            </li>
                            <li>
                                <strong>' ~ "Source Tracking"|t('smartlink-manager') ~ '</strong> –
                                ' ~ "{rmPluginName} shows which plugin created each redirect for better organization"|t('smartlink-manager', {rmPluginName: rmPluginName}) ~ '
                            </li>
                        </ul>'
                } %}
            {% endblock %}
        {% endembed %}

        {# Hidden field to track enabled integrations #}
        {% set enabledIntegrationsArray = [] %}
        {% if seomaticAvailable and seomaticEnabled %}
            {% set enabledIntegrationsArray = enabledIntegrationsArray|merge(['seomatic']) %}
        {% endif %}
        {% if rmAvailable and rmIntegrationEnabled %}
            {% set enabledIntegrationsArray = enabledIntegrationsArray|merge(['redirect-manager']) %}
        {% endif %}

        <input type="hidden"
               name="settings[enabledIntegrations]"
               value="{{ enabledIntegrationsArray|json_encode }}"
               id="enabledIntegrationsField">

        {% js %}
            // Rebuild the aggregate enabled-integrations hidden field from the
            // per-integration switches. Card body show/hide is handled in base
            // components.js (lrIntegrationCards).
            function updateEnabledIntegrations() {
                var integrations = [];

                if ($('#enableSeomaticIntegration').length && $('#enableSeomaticIntegration').find('input[type="hidden"]').val() === '1') {
                    integrations.push('seomatic');
                }

                if ($('#enableRedirectManagerIntegration').length && $('#enableRedirectManagerIntegration').find('input[type="hidden"]').val() === '1') {
                    integrations.push('redirect-manager');
                }

                $('#enabledIntegrationsField').val(JSON.stringify(integrations));
            }

            $('#enableSeomaticIntegration').on('change', updateEnabledIntegrations);
            $('#enableRedirectManagerIntegration').on('change', updateEnabledIntegrations);
        {% endjs %}

    {% include 'lindemannrock-base/_components/plugin-credit' %}
{% endblock %}
