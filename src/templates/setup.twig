{% extends "smartlink-manager/_layouts/cp" %}

{% set selectedSubnavItem = 'setup' %}
{% set title = "Set up SmartLink Manager"|t('smartlink-manager') %}

{% set missingTemplates = templateStatuses|filter(status => not status.exists) %}
{% set templatesReady = missingTemplates|length == 0 %}
{% set allComplete = ipSaltConfigured and templatesReady %}
{% set smartlinkFullNameHtml = smartlinkHelper.fullName|e %}

{% set ipSaltIncompleteBody %}
    <p>
        {{ 'Analytics tracking requires a secure salt for privacy protection.'|t('lindemannrock-base') }}
    </p>
    <p>
        <strong>{{ 'Run one of these commands in your terminal:'|t('lindemannrock-base') }}</strong>
    </p>
{% endset %}

{% set ipSaltFooter %}
    <p>
        {{ 'This will automatically add {envVar} to your .env file.'|t('lindemannrock-base', {envVar: '<code>SMARTLINK_MANAGER_IP_SALT</code>'})|raw }}
    </p>
    <p>
        <strong>{{ 'Note:'|t('smartlink-manager') }}</strong>
        {{ 'Copy the same salt to staging and production environments.'|t('lindemannrock-base') }}
    </p>
{% endset %}

{% set templateCompleteBody %}
    <p>{{ 'All required frontend templates are available.'|t('smartlink-manager') }}</p>
{% endset %}

{% set templatesIncompleteBody %}
    <p>
        {{ (missingTemplates|length == 1 ? 'Copy the missing starter template before public smart links can render this frontend page.' : 'Copy the missing starter templates before public smart links can render redirect or QR pages.')|t('smartlink-manager') }}
    </p>
    <p>
        <strong>{{ 'Run one of these commands in your terminal:'|t('lindemannrock-base') }}</strong>
    </p>
{% endset %}

{% set templateCopyCommands = [
    {
        legend: 'Standard:'|t('lindemannrock-base'),
        value: 'php craft smartlink-manager/setup/copy-templates',
        copyLabel: 'Copy'|t('lindemannrock-base'),
        copiedMessage: 'Copied!'|t('lindemannrock-base'),
    },
    {
        legend: 'DDEV:'|t('lindemannrock-base'),
        value: 'ddev craft smartlink-manager/setup/copy-templates',
        copyLabel: 'Copy'|t('lindemannrock-base'),
        copiedMessage: 'Copied!'|t('lindemannrock-base'),
    },
] %}

{% set templatesFooter %}
    <p>
        <strong>{{ 'Note:'|t('smartlink-manager') }}</strong>
        {{ 'Review and customize the copied templates before going live.'|t('smartlink-manager') }}
    </p>
{% endset %}

{% set setupConfig = {
    plugin: {
        handle: 'smartlink-manager',
        name: smartlinkHelper.fullName,
        version: pluginVersion ? ('v{version}'|t('smartlink-manager', {version: pluginVersion})) : null,
        iconSvg: pluginIconSvg,
        logoPaths: logoPaths,
        heroStyle: pluginHeroStyle,
    },
    page: {
        badge: allComplete ? 'Ready'|t('smartlink-manager') : 'Setup'|t('smartlink-manager'),
        title: smartlinkHelper.fullName,
        description: 'Complete these steps before creating public smart links and QR landing pages.'|t('smartlink-manager'),
    },
    tasks: [
        {
            done: ipSaltConfigured,
            heading: 'IP salt'|t('smartlink-manager'),
            description: ipSaltConfigured ? 'Analytics privacy salt is ready for public smart link tracking.'|t('smartlink-manager') : 'Analytics needs a privacy salt before public smart link tracking is ready.'|t('smartlink-manager'),
            complete: {
                heading: 'IP hash salt is configured.'|t('smartlink-manager'),
                body: 'Analytics privacy salt is ready for public smart link tracking.'|t('smartlink-manager'),
            },
            incomplete: {
                heading: 'IP hash salt is missing.'|t('lindemannrock-base'),
                bodyHtml: ipSaltIncompleteBody,
                commands: [
                    {
                        legend: 'Standard:'|t('lindemannrock-base'),
                        value: 'php craft smartlink-manager/security/generate-salt',
                        copyLabel: 'Copy'|t('lindemannrock-base'),
                        copiedMessage: 'Copied!'|t('lindemannrock-base'),
                    },
                    {
                        legend: 'DDEV:'|t('lindemannrock-base'),
                        value: 'ddev craft smartlink-manager/security/generate-salt',
                        copyLabel: 'Copy'|t('lindemannrock-base'),
                        copiedMessage: 'Copied!'|t('lindemannrock-base'),
                    },
                ],
                footerHtml: ipSaltFooter,
            },
        },
        {
            done: templatesReady,
            heading: 'Starter templates'|t('smartlink-manager'),
            description: templatesReady ? 'All required frontend templates are available.'|t('smartlink-manager') : 'Copy the starter templates before public smart links can render their frontend pages.'|t('smartlink-manager'),
            complete: {
                heading: 'Starter templates are ready.'|t('smartlink-manager'),
                bodyHtml: templateCompleteBody,
            },
            incomplete: {
                heading: (missingTemplates|length == 1 ? 'Starter template is missing.' : 'Starter templates are missing.')|t('smartlink-manager'),
                bodyHtml: templatesIncompleteBody,
                commands: templateCopyCommands,
                footerHtml: templatesFooter,
            },
        },
    ],
} %}

{% block content %}
    {% embed 'lindemannrock-base/_layouts/cp-plugin-setup' with {
        setupConfig: setupConfig,
        allComplete: allComplete,
        ipSaltConfigured: ipSaltConfigured,
        templatesReady: templatesReady,
        templateStatuses: templateStatuses,
        missingTemplates: missingTemplates,
        pluginIconSvg: pluginIconSvg,
        pluginHeroStyle: pluginHeroStyle,
        logoPaths: logoPaths,
        smartlinkFullNameHtml: smartlinkFullNameHtml,
    } only %}
        {% block summary %}
            {% if allComplete %}
                {% include 'lindemannrock-base/_components/info-box' with {
                    message: '<strong>' ~ 'Setup complete.'|t('smartlink-manager') ~ '</strong> ' ~ '{pluginName} is ready to create public smart links and QR landing pages.'|t('smartlink-manager', {
                        pluginName: smartlinkFullNameHtml,
                    }),
                    type: 'success',
                    variant: 'colored',
                    margin: 'none',
                    allowHtml: true,
                } only %}
            {% endif %}
        {% endblock %}
        {% block additionalContent %}
            <section class="lr-setup-task">
                <div class="lr-setup-task__section-header">
                    <h4 class="lr-setup-task__subheading">{{ 'Template locations'|t('smartlink-manager') }}</h4>
                </div>
                <div class="lr-setup-task__body">
                    {% for templateStatus in templateStatuses %}
                        {% set templateLocationMessage %}
                            <strong>{{ templateStatus.label }}</strong>
                            <span class="light">{{ templateStatus.exists ? 'Ready'|t('smartlink-manager') : 'Missing'|t('smartlink-manager') }}</span><br>
                            <span class="light">{{ 'Bundled template:'|t('smartlink-manager') }}</span>
                            <code>{{ templateStatus.source }}</code><br>
                            <span class="light">{{ 'Site template:'|t('smartlink-manager') }}</span>
                            <code>{{ templateStatus.destination }}</code>
                        {% endset %}
                        {% include 'lindemannrock-base/_components/info-box' with {
                            type: templateStatus.exists ? 'success' : 'warning',
                            variant: 'subtle',
                            margin: loop.first ? 'none' : 'top',
                            message: templateLocationMessage,
                            allowHtml: true,
                        } only %}
                    {% endfor %}
                </div>
            </section>
        {% endblock %}
    {% endembed %}
{% endblock %}
