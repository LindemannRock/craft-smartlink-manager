{
  "name": "@lindemannrock/smartlink-manager",
  "version": "1.0.0",
  "private": true,
  "description": "Build tools for SmartLink Manager asset packages",
  "scripts": {
    "build": "npm run build:analytics && npm run build:qr-preview && npm run build:edit",
    "build:analytics": "mkdir -p analytics/dist && terser analytics/src/analytics.js -o analytics/dist/analytics.js -c -m",
    "build:qr-preview": "mkdir -p qrpreview/dist && terser qrpreview/src/qr-preview.js -o qrpreview/dist/qr-preview.js -c -m",
    "build:edit": "mkdir -p edit/dist && terser edit/src/edit.js -o edit/dist/edit.js -c -m"
  },
  "devDependencies": {
    "terser": "^5.46.1"
  },
  "author": {
    "name": "Bilal Harry Lindemann",
    "email": "hello@lindemannrock.com",
    "url": "https://lindemannrock.com"
  },
  "company": {
    "name": "LindemannRock",
    "url": "https://lindemannrock.com"
  },
  "license": "Proprietary"
}
